<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tarefas - Healthy Safely</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/hs-user-dashboard.css" />
    <link rel="stylesheet" href="/css/tasks.css" />
</head>
<body>

<%- include('../partials/header.ejs') %>
<%- include('../partials/menu-inferior.ejs') %>

<main class="hs-tasks-main">
  <!-- Header Seção de Tarefas -->
  <section class="hs-user-header">
    <h1>Suas Tarefas</h1>
    <p>Organize seu dia e marque tudo que já foi feito</p>
  </section>

  <!-- Seção para criar nova tarefa -->
  <section class="hs-new-task-section">
    <article class="hs-new-task-card">
      <form id="formNovaTarefa" class="hs-task-form">
        <div class="hs-form-group">
          <input 
            type="text"
            id="campoTarefa"
            placeholder="Adicione uma nova tarefa..."
            required
            class="hs-task-input"
          />
          <button type="submit" class="hs-add-task-btn">
            <i class="bi bi-plus-circle"></i>
            Adicionar
          </button>
        </div>
      </form>
    </article>
  </section>

  <!-- Lista de Tarefas -->
  <section class="hs-tasks-section">
    <h2 class="hs-section-title">Tarefas do Dia</h2>
    
    <% if(tasks && tasks.length > 0){ %>
      <div class="hs-user-tasks">
        <% tasks.forEach((tarefa, index) => { %>
          <article class="hs-user-task-card <%= tarefa.completed ? 'hs-task-completed' : '' %>">
            <div class="hs-task-header">
              <div class="hs-task-left">
                <div class="hs-task-icon">
                  <% if(tarefa.completed) { %>
                    <i class="bi bi-check-circle-fill"></i>
                  <% } else { %>
                    <i class="bi bi-circle"></i>
                  <% } %>
                </div>
                <div class="hs-task-content">
                  <h3 class="hs-task-name"><%= tarefa.title %></h3>
                </div>
              </div>
              <form action="/tasks/complete/<%= tarefa._id %>" method="POST" class="hs-task-form-action">
                <button 
                  type="submit" 
                  class="hs-task-btn <%= tarefa.completed ? 'hs-btn-completed' : '' %>"
                  <% if(tarefa.completed) { %>disabled<% } %>
                >
                  <% if(tarefa.completed) { %>
                    <i class="bi bi-check"></i> Concluída
                  <% } else { %>
                    <i class="bi bi-check"></i> Concluir
                  <% } %>
                </button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="hs-empty-state">
        <i class="bi bi-inbox"></i>
        <p class="hs-empty-title">Nenhuma tarefa</p>
        <p class="hs-empty-subtitle">Crie sua primeira tarefa para começar!</p>
      </div>
    <% } %>
  </section>
</main>

<script src="/js/tasks.js"></script>

</section>

</main>
    

    <%- include('../partials/footer.ejs') %>
</body>

<script src="/js/tasks.js"></script>