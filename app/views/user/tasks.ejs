<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tarefas | Healthy Safely</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/tasks.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>

<%- include('../partials/header.ejs') %>
<%- include('../partials/menu-inferior.ejs') %>

<!-- Hero -->
<section class="tasks-hero" aria-labelledby="tasks-titulo">
  <h1 id="tasks-titulo">Suas Tarefas</h1>
  <p>Organize seu dia e marque tudo que já foi feito</p>
</section>

<!-- Barra de adição flutuante -->
<section class="tasks-add-bar" aria-label="Adicionar nova tarefa">
  <section class="tasks-add-inner">
    <label for="campoTarefa" class="visually-hidden">Nova tarefa</label>
    <input
      type="text"
      id="campoTarefa"
      class="hs-task-input"
      placeholder="Adicione uma nova tarefa..."
      aria-label="Digite a nova tarefa"
    />
    <button type="button" class="hs-add-task-btn" onclick="adicionarTarefa()">
      <i class="bi bi-plus-circle" aria-hidden="true"></i>
      Adicionar
    </button>
  </section>
</section>

<!-- Conteúdo principal -->
<main class="hs-tasks-main">

  <!-- Tarefas do servidor -->
  <section class="hs-tasks-section" aria-labelledby="titulo-tarefas">
    <header class="tasks-section-header">
      <h2 class="hs-section-title" id="titulo-tarefas">Tarefas do Dia</h2>
    </header>

    <% if(tasks && tasks.length > 0){ %>
      <ul class="hs-user-tasks" id="listaTarefasServidor" aria-label="Tarefas do dia">
        <% tasks.forEach((tarefa) => { %>
          <li>
            <article class="hs-user-task-card <%= tarefa.completed ? 'hs-task-completed' : '' %>">
              <header class="hs-task-header">
                <section class="hs-task-left">
                  <figure class="hs-task-icon" aria-hidden="true">
                    <% if(tarefa.completed) { %>
                      <i class="bi bi-check-circle-fill"></i>
                    <% } else { %>
                      <i class="bi bi-circle"></i>
                    <% } %>
                  </figure>
                  <section class="hs-task-content">
                    <h3 class="hs-task-name"><%= tarefa.title %></h3>
                  </section>
                </section>
                <form action="/tasks/complete/<%= tarefa._id %>" method="POST">
                  <button
                    type="submit"
                    class="hs-task-btn <%= tarefa.completed ? 'hs-btn-completed' : '' %>"
                    <%= tarefa.completed ? 'disabled' : '' %>
                  >
                    <i class="bi bi-check" aria-hidden="true"></i>
                    <%= tarefa.completed ? 'Concluída' : 'Concluir' %>
                  </button>
                </form>
              </header>
            </article>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <section class="hs-empty-state" id="estadoVazio">
        <i class="bi bi-inbox" aria-hidden="true"></i>
        <p class="hs-empty-title">Nenhuma tarefa ainda</p>
        <p class="hs-empty-subtitle">Use o campo acima para adicionar sua primeira tarefa!</p>
      </section>
    <% } %>

    <!-- Tarefas adicionadas localmente -->
    <ul class="hs-user-tasks" id="listaTarefasLocais" aria-label="Tarefas adicionadas" aria-live="polite" style="margin-top:.75rem"></ul>
  </section>

  <!-- Categorias de saúde -->
  <section class="hs-tasks-section" aria-labelledby="titulo-cats">
    <header class="tasks-section-header">
      <h2 class="hs-section-title" id="titulo-cats">Categorias de Saúde</h2>
    </header>
    <nav class="hs-categorias" aria-label="Navegar por categoria">
      <a href="/sono" class="hs-categoria-link">
        <img src="/imagem/sono.png" alt="" aria-hidden="true" />
        <span>Sono</span>
      </a>
      <a href="/saude-mental" class="hs-categoria-link">
        <img src="/imagem/saudemental.png" alt="" aria-hidden="true" />
        <span>Saúde Mental</span>
      </a>
      <a href="/atividade-fisica" class="hs-categoria-link">
        <img src="/imagem/atf.png" alt="" aria-hidden="true" />
        <span>Atividade Física</span>
      </a>
      <a href="/alimentacao" class="hs-categoria-link">
        <img src="/imagem/alimentacao.png" alt="" aria-hidden="true" />
        <span>Alimentação</span>
      </a>
    </nav>
  </section>

</main>

<%- include('../partials/footer.ejs') %>

<script>
  function adicionarTarefa() {
    const campo = document.getElementById('campoTarefa');
    const texto = campo.value.trim();
    if (!texto) { campo.focus(); return; }

    const lista = document.getElementById('listaTarefasLocais');
    const vazio = document.getElementById('estadoVazio');
    if (vazio) vazio.style.display = 'none';

    const li = document.createElement('li');
    li.innerHTML = `
      <article class="hs-user-task-card">
        <header class="hs-task-header">
          <section class="hs-task-left">
            <figure class="hs-task-icon" aria-hidden="true">
              <i class="bi bi-circle"></i>
            </figure>
            <section><h3 class="hs-task-name">${texto}</h3></section>
          </section>
          <button type="button" class="hs-task-btn" onclick="concluirTarefa(this)">
            <i class="bi bi-check" aria-hidden="true"></i> Concluir
          </button>
        </header>
      </article>`;
    lista.appendChild(li);
    campo.value = '';
    campo.focus();
  }

  function concluirTarefa(btn) {
    const card = btn.closest('.hs-user-task-card');
    card.classList.add('hs-task-completed');
    card.querySelector('.hs-task-icon i').className = 'bi bi-check-circle-fill';
    btn.innerHTML = '<i class="bi bi-check"></i> Concluída';
    btn.disabled = true;
    btn.classList.add('hs-btn-completed');
  }

  document.getElementById('campoTarefa').addEventListener('keydown', e => {
    if (e.key === 'Enter') adicionarTarefa();
  });
</script>
</body>
</html>
