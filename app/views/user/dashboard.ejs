<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Healthy Safely</title>
  <link rel="stylesheet" href="/css/hs-user-dashboard.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>
  <%- include('../partials/header.ejs') %>
  <%- include('../partials/menu-inferior.ejs') %>

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="db-hero" aria-labelledby="db-saudacao">
    <section class="db-hero-inner">
      <section class="db-hero-text">
        <span class="db-hero-tag">
          <i class="bi bi-lightning-fill"></i> Seu plano de hoje
        </span>
        <h1 id="db-saudacao">
          Olá, <span><%= nome ? nome.split(' ')[0] : 'Usuário' %>!</span>
        </h1>
        <p class="db-hero-sub">
          Cada hábito construído hoje é um passo rumo à melhor versão de você.
          Vamos começar? 💪
        </p>
        <nav class="db-hero-actions">
          <a href="/tasks" class="db-btn-primary">
            <i class="bi bi-check2-circle"></i> Ver tarefas
          </a>
          <a href="/perfil" class="db-btn-ghost">
            <i class="bi bi-person-circle"></i> Meu perfil
          </a>
        </nav>
      </section>

      <figure class="db-hero-visual" aria-hidden="true">
        <img
          src="/imagem/1x/bannerprogresso.png"
          alt="Banner de progresso"
          class="db-hero-img"
        />
        <section class="db-hero-badge">
          <i class="bi bi-trophy-fill"></i>
          Nível: <strong><%= nivel || 'Iniciante' %></strong>
        </section>
      </figure>
    </section>
  </section>

  <!-- ── STATS ─────────────────────────────────────────────── -->
  <section class="db-stats-strip" aria-label="Suas estatísticas">
    <article class="db-stat">
      <figure class="db-stat-icon estrela" aria-hidden="true">⭐</figure>
      <section>
        <p class="db-stat-label">Pontos acumulados</p>
        <p class="db-stat-value" id="hs-pontos">0</p>
      </section>
    </article>
    <article class="db-stat">
      <figure class="db-stat-icon dias" aria-hidden="true">📅</figure>
      <section>
        <p class="db-stat-label">Dias ativos</p>
        <p class="db-stat-value" id="hs-dias">0</p>
      </section>
    </article>
    <article class="db-stat">
      <figure class="db-stat-icon pct" aria-hidden="true">📈</figure>
      <section>
        <p class="db-stat-label">Progresso da semana</p>
        <p class="db-stat-value" id="hs-percent">0%</p>
      </section>
    </article>
  </section>

  <!-- ── MAIN ──────────────────────────────────────────────── -->
  <main class="db-main">

    <!-- Tarefas do dia -->
    <section aria-labelledby="titulo-tarefas-hoje">
      <header class="db-section-header">
        <h2 class="db-section-title" id="titulo-tarefas-hoje">Tarefas de Hoje</h2>
        <a href="/tasks" class="db-section-link">Ver todas →</a>
      </header>
      <section class="hs-user-tasks" id="hs-user-tasks" aria-live="polite">
        <!-- cards injetados via JS -->
      </section>
    </section>

    <!-- Categorias de saúde -->
    <section aria-labelledby="titulo-cats">
      <header class="db-section-header">
        <h2 class="db-section-title" id="titulo-cats">Áreas de Saúde</h2>
      </header>
      <nav class="db-cats" aria-label="Categorias de saúde">
        <a href="/sono" class="db-cat-card">
          <img src="/imagem/sono.png" alt="" class="db-cat-img" aria-hidden="true" />
          <strong class="db-cat-name">Sono</strong>
          <span class="db-cat-desc">Qualidade e duração do descanso</span>
        </a>
        <a href="/saude-mental" class="db-cat-card">
          <img src="/imagem/saudemental.png" alt="" class="db-cat-img" aria-hidden="true" />
          <strong class="db-cat-name">Saúde Mental</strong>
          <span class="db-cat-desc">Meditação e equilíbrio emocional</span>
        </a>
        <a href="/atividade-fisica" class="db-cat-card">
          <img src="/imagem/atf.png" alt="" class="db-cat-img" aria-hidden="true" />
          <strong class="db-cat-name">Atividade Física</strong>
          <span class="db-cat-desc">Treinos e condicionamento</span>
        </a>
        <a href="/alimentacao" class="db-cat-card">
          <img src="/imagem/alimentacao.png" alt="" class="db-cat-img" aria-hidden="true" />
          <strong class="db-cat-name">Alimentação</strong>
          <span class="db-cat-desc">Hábitos e diário alimentar</span>
        </a>
      </nav>
    </section>

  </main>

  <!-- ── Modal de tarefa ───────────────────────────────────── -->
  <section class="hs-user-modal" id="hs-user-modal" role="dialog" aria-modal="true" aria-labelledby="hs-user-modal-title" aria-hidden="true">
    <article class="hs-user-modal-content">
      <button class="hs-user-modal-close" id="hs-user-modal-close" aria-label="Fechar">&times;</button>
      <h2 id="hs-user-modal-title"></h2>
      <p id="hs-user-modal-desc"></p>
      <section class="hs-user-progress">
        <section class="progress-bar"><section class="fill" id="hs-user-modal-fill"></section></section>
        <span class="percent-label" id="hs-user-modal-percent">0%</span>
      </section>
      <button class="hs-user-btn" id="hs-user-modal-button">Marcar como Concluída</button>
    </article>
  </section>

  <section class="footer"><%- include('../partials/footer.ejs') %></section>

  <script>
    const nivel = '<%= nivel %>' || 'iniciante';
    let pontos = Number(localStorage.getItem('hs_pontos') || 0);
    let diasAtivos = Number(localStorage.getItem('hs_diasAtivos') || 1);
    let semanaPercent = Number(localStorage.getItem('hs_semanaPercent') || 0);

    const baseTarefas = {
      iniciante: [
        { id: 'i1', nome: 'Caminhada 20 minutos', icone: '🚶', descricao: 'Uma caminhada leve para iniciar o dia com energia.', progresso: 0 },
        { id: 'i2', nome: 'Beber 2L de água',     icone: '💧', descricao: 'Hidratação ao longo do dia melhora disposição e saúde.', progresso: 0 },
        { id: 'i3', nome: 'Alongamento leve',     icone: '🧘', descricao: 'Alongamentos simples por 10–15 minutos.', progresso: 0 },
      ],
      intermediario: [
        { id: 'm1', nome: 'Corrida 30 minutos',       icone: '🏃', descricao: 'Corrida moderada para condicionamento cardiovascular.', progresso: 0 },
        { id: 'm2', nome: 'Treino funcional',          icone: '💪', descricao: 'Exercícios para força e resistência muscular.', progresso: 0 },
        { id: 'm3', nome: 'Alongamento + mobilidade', icone: '🤸', descricao: 'Mobilidade articular e alongamento completo.', progresso: 0 },
      ],
      avancado: [
        { id: 'a1', nome: 'HIIT 25 minutos',   icone: '⚡', descricao: 'Treino intervalado de alta intensidade.', progresso: 0 },
        { id: 'a2', nome: 'Treino de força',    icone: '🏋️', descricao: 'Séries com carga para ganho de força.', progresso: 0 },
        { id: 'a3', nome: 'Alongamento intenso', icone: '🧘‍♀️', descricao: 'Alongamentos profundos para flexibilidade máxima.', progresso: 0 },
      ],
    };

    let tarefas = JSON.parse(JSON.stringify(baseTarefas[nivel] || baseTarefas['iniciante']));

    function atualizarEstatisticas() {
      document.getElementById('hs-pontos').textContent = pontos;
      document.getElementById('hs-dias').textContent = diasAtivos;
      document.getElementById('hs-percent').textContent = semanaPercent + '%';
    }

    function animarPontos() {
      const el = document.getElementById('hs-pontos');
      el.classList.add('pontos-anim');
      setTimeout(() => el.classList.remove('pontos-anim'), 600);
    }

    function calcularSemanaPercent() {
      if (!tarefas.length) return 0;
      return Math.round((tarefas.filter(t => t.progresso === 100).length / tarefas.length) * 100);
    }

    function salvarEstado() {
      localStorage.setItem('hs_pontos', String(pontos));
      localStorage.setItem('hs_diasAtivos', String(diasAtivos));
      localStorage.setItem('hs_semanaPercent', String(semanaPercent));
      localStorage.setItem('hs_tarefas_' + nivel, JSON.stringify(tarefas));
    }

    function carregarEstado() {
      const gravadas = localStorage.getItem('hs_tarefas_' + nivel);
      if (gravadas) {
        try { const a = JSON.parse(gravadas); if (Array.isArray(a) && a.length) tarefas = a; } catch(e) {}
      }
      if (!localStorage.getItem('hs_diasAtivos')) diasAtivos = Math.floor(Math.random() * 7) + 1;
      if (!localStorage.getItem('hs_semanaPercent')) semanaPercent = calcularSemanaPercent();
      atualizarEstatisticas();
    }

    function criarCardDOM(tarefa, idx) {
      const card = document.createElement('article');
      card.className = 'hs-user-task-card' + (tarefa.progresso === 100 ? ' concluida' : '');
      card.dataset.index = idx;
      const fill = tarefa.progresso || 0;
      card.innerHTML = `
        <section class="hs-user-task-icon">${tarefa.icone}</section>
        <p class="hs-user-task-name">${tarefa.nome}</p>
        <p class="hs-user-task-desc">${tarefa.descricao}</p>
        <section class="hs-user-progress">
          <section class="progress-bar"><section class="fill" style="width:${fill}%"></section></section>
          <span class="percent-label">${fill}%</span>
        </section>
        <button class="hs-user-btn" ${tarefa.progresso===100?'disabled':''}>
          ${tarefa.progresso===100 ? '✓ Concluída' : 'Iniciar'}
        </button>
        ${tarefa.progresso===100 ? '<span class="hs-task-badge">✓ Concluído</span>' : ''}
      `;
      return card;
    }

    function renderizarTarefas() {
      const c = document.getElementById('hs-user-tasks');
      c.innerHTML = '';
      tarefas.forEach((t, i) => c.appendChild(criarCardDOM(t, i)));
    }

    function abrirModalPorIndice(idx) {
      const t = tarefas[idx]; if (!t) return;
      const modal = document.getElementById('hs-user-modal');
      document.getElementById('hs-user-modal-title').textContent = t.nome;
      document.getElementById('hs-user-modal-desc').textContent = t.descricao;
      document.getElementById('hs-user-modal-fill').style.width = (t.progresso||0) + '%';
      document.getElementById('hs-user-modal-percent').textContent = (t.progresso||0) + '%';
      modal.dataset.index = idx;
      modal.classList.add('active');
      modal.setAttribute('aria-hidden', 'false');
    }

    function fecharModal() {
      const modal = document.getElementById('hs-user-modal');
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
      delete modal.dataset.index;
    }

    function concluirTarefaAtual() {
      const modal = document.getElementById('hs-user-modal');
      const idx = Number(modal.dataset.index);
      if (Number.isNaN(idx)) return;
      const t = tarefas[idx]; if (!t) return;
      t.progresso = 100;
      pontos += 10;
      semanaPercent = calcularSemanaPercent();
      renderizarTarefas();
      atualizarEstatisticas();
      animarPontos();
      salvarEstado();
      setTimeout(() => fecharModal(), 500);
    }

    document.addEventListener('click', e => {
      const card = e.target.closest('.hs-user-task-card');
      if (card) { abrirModalPorIndice(Number(card.dataset.index)); return; }
      if (e.target.id === 'hs-user-modal-close') { fecharModal(); return; }
      if (e.target.id === 'hs-user-modal-button') { concluirTarefaAtual(); return; }
    });

    document.getElementById('hs-user-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) fecharModal();
    });

    document.addEventListener('DOMContentLoaded', () => {
      carregarEstado();
      semanaPercent = calcularSemanaPercent();
      renderizarTarefas();
      atualizarEstatisticas();
    });

    window.hs = { renderizarTarefas, salvarEstado, carregarEstado };
  </script>
</body>
</html>
