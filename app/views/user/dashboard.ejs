<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <script src="/js/darkmode.js"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Healthy Safely</title>
    <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/hs-user-dashboard.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>
  <%- include('../partials/header.ejs') %>

  <%
    const nivelMap = {
      iniciante:     { label:'🌱 Iniciante',    max: 100,  proximo: 'Em Evolução' },
      intermediario: { label:'📈 Em Evolução',  max: 300,  proximo: 'Avançado'   },
      avancado:      { label:'⚡ Avançado',       max: 600,  proximo: 'Elite'      },
      elite:         { label:'🏆 Elite',          max: 9999, proximo: '—'          },
    };
    const ncfg     = nivelMap[nivel] || nivelMap.iniciante;
    const pontosTpl = typeof pontos !== 'undefined' ? pontos : 0;
    const pctNivel = Math.min(Math.round((pontosTpl / ncfg.max) * 100), 100);
    const pctSem   = typeof pctSemana !== 'undefined' ? pctSemana : 0;
    const taskList = typeof tasks !== 'undefined' ? tasks : [];
    const feitas   = taskList.filter(t => t.completed).length;
  %>

  <main class="hs-main hs-main-spaced">

    <section class="hs-page-head card-base" aria-label="Boas-vindas">
      <section class="hs-page-head-copy">
        <span class="hs-page-kicker">Dashboard</span>
        <h1>Olá, <span><%= nome ? nome.split(' ')[0] : 'Usuário' %></span></h1>
        <p>Continue construindo seus hábitos com uma visão clara do seu progresso.</p>
      </section>
      <nav class="hs-hero-btns" aria-label="Ações rápidas">
        <a href="/tasks" class="hs-btn-hero-prim">
          <i class="bi bi-check2-circle"></i> Minhas tarefas
        </a>
        <a href="/perfil" class="hs-btn-hero-prim">
          <i class="bi bi-person-circle"></i> Perfil
        </a>
      </nav>
    </section>

  <!-- BARRA DE NÍVEL ──────────────────────────────────── -->
  <section class="hs-nivel-wrap" aria-label="Barra de nível">
    <section class="hs-nivel-card">
      <section class="hs-nivel-info">

        <span class="hs-nivel-label"><%= ncfg.label %></span>
        <span class="hs-nivel-pts">
          <%= pontosTpl %> / <%= ncfg.max %> pts
          <% if (ncfg.proximo !== '—') { %> · Próximo: <strong><%= ncfg.proximo %></strong><% } %>
        </span>
      </section>
      <section class="hs-nivel-track"
        role="progressbar" aria-valuenow="<%= pctNivel %>" aria-valuemin="0" aria-valuemax="100">
        <section class="hs-nivel-fill" style="width:<%= pctNivel %>%"></section>
      </section>
    </section>
  </section>

  <!-- STATS STRIP ─────────────────────────────────────── -->
  <section class="hs-user-stats" aria-label="Estatísticas">
    <article class="hs-user-stat-card">
      <figure class="hs-user-stat-icon ic-a" aria-hidden="true">⭐</figure>
      <section class="hs-user-stat-body">
        <p class="hs-user-stat-title">Pontos</p>
        <p class="hs-user-stat-value" id="hs-pontos"><%= pontosTpl %></p>
      </section>
    </article>
    <article class="hs-user-stat-card">
      <figure class="hs-user-stat-icon ic-b" aria-hidden="true">📊</figure>
      <section class="hs-user-stat-body">
        <p class="hs-user-stat-title">Semana</p>
        <p class="hs-user-stat-value" id="hs-percent"><%= pctSem %>%</p>
      </section>
    </article>
    <article class="hs-user-stat-card">
      <figure class="hs-user-stat-icon ic-c" aria-hidden="true">✅</figure>
      <section class="hs-user-stat-body">
        <p class="hs-user-stat-title">Feitas hoje</p>
        <p class="hs-user-stat-value" id="hs-dias"><%= feitas %></p>
      </section>
    </article>
    <article class="hs-user-stat-card">
      <figure class="hs-user-stat-icon ic-d" aria-hidden="true">🏅</figure>
      <section class="hs-user-stat-body">
        <p class="hs-user-stat-title">Nível</p>
        <p class="hs-user-stat-value" style="font-size:.9rem;text-transform:capitalize">
          <%= nivel || 'iniciante' %>
        </p>
      </section>
    </article>
  </section>

    <!-- Tarefas de hoje -->
    <section class="hs-tasks-section" aria-labelledby="tit-tarefas">
      <header class="hs-section-header">
        <h2 class="hs-section-title" id="tit-tarefas">Tarefas de Hoje</h2>
        <a href="/tasks" class="hs-section-link">Ver todas →</a>
      </header>

      <% if (!taskList.length) { %>
        <section class="empty-state">
          <i class="bi bi-inbox"></i>
          <p style="font-weight:700">Nenhuma tarefa ainda</p>
          <p><a href="/tasks" style="color:#1a8a75;font-weight:600">Adicione sua primeira tarefa</a></p>
        </section>
      <% } else { %>
      <main class="hs-user-tasks" id="hs-user-tasks">
        <% taskList.slice(0,6).forEach((t, i) => {
             const icones = {saude:'💊',sono:'🌙',alimentacao:'🥗',exercicio:'💪',geral:'✅'};
             const icone  = icones[t.categoria] || '✅';
           %>
        <article class="hs-user-task-card <%= t.completed ? 'concluida' : '' %>"
          data-index="<%= i %>">
          <figure class="hs-user-task-icon"><%= icone %></figure>
          <p class="hs-user-task-name"
            style="<%= t.completed ? 'text-decoration:line-through;opacity:.6' : '' %>">
            <%= t.title %>
          </p>
          <section class="hs-user-progress">
            <section class="progress-bar">
              <section class="fill" style="width:<%= t.completed ? 100 : 0 %>%"></section>
            </section>
            <span class="percent-label"><%= t.completed ? 100 : 0 %>%</span>
          </section>
          <% if (!t.completed) { %>
            <a href="/tasks/concluir?id=<%= t._id %>" class="hs-user-btn">
              <i class="bi bi-check-circle"></i> Concluir
            </a>
          <% } else { %>
            <button class="hs-user-btn" disabled>✓ Concluída</button>
            <span class="hs-task-badge">✓</span>
          <% } %>
        </article>
        <% }) %>
      </main>
      <% } %>
    </section>

    <!-- Categorias de saúde -->
    <section class="hs-tasks-section" aria-labelledby="tit-cats">
      <h2 class="hs-section-title" id="tit-cats">Áreas de Saúde</h2>
      <nav class="hs-categorias" aria-label="Categorias">
        <a href="/sono" class="hs-categoria-link">
          <img src="/imagem/sono.png" alt="" aria-hidden="true" />
          <span>Sono</span>
        </a>
        <a href="/saude-mental" class="hs-categoria-link">
          <img src="/imagem/saudemental.png" alt="" aria-hidden="true" />
          <span>Saúde Mental</span>
        </a>
        <a href="/atividade-fisica" class="hs-categoria-link">
          <img src="/imagem/atf.png" alt="" aria-hidden="true" />
          <span>Atividade Física</span>
        </a>
        <a href="/alimentacao" class="hs-categoria-link">
          <img src="/imagem/alimentacao.png" alt="" aria-hidden="true" />
          <span>Alimentação</span>
        </a>
      </nav>
    </section>

  </main>

  <!-- Modal -->
  <section class="hs-user-modal" id="hs-user-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <article class="hs-user-modal-content">
      <button class="hs-user-modal-close" id="hs-user-modal-close" aria-label="Fechar">&times;</button>
      <h2 id="hs-user-modal-title"></h2>
      <p id="hs-user-modal-desc"></p>
      <section class="hs-user-progress">
        <section class="progress-bar">
          <section class="fill" id="hs-user-modal-fill"></section>
        </section>
        <span class="percent-label" id="hs-user-modal-percent">0%</span>
      </section>
      <button class="hs-user-btn" id="hs-user-modal-button" style="margin-top:.75rem">
        Marcar como Concluída
      </button>
    </article>
  </section>

<%- include('../partials/footer.ejs') %>

  <script>
    const nivel = '<%= nivel %>' || 'iniciante';
    let pontos       = <%= typeof pontos !== 'undefined' ? pontos : 0 %>;
    let diasAtivos   = Number(localStorage.getItem('hs_diasAtivos') || 1);
    let semanaPercent= <%= typeof pctSemana !== 'undefined' ? pctSemana : 0 %>;

    const baseTarefas = {
      iniciante:     [
        { id:'i1', nome:'Caminhada 20 min',      icone:'🚶', descricao:'Caminhada leve para começar o dia.',     progresso:0 },
        { id:'i2', nome:'Beber 2L de água',       icone:'💧', descricao:'Hidratação melhora disposição e saúde.',progresso:0 },
        { id:'i3', nome:'Alongamento leve',       icone:'🧘', descricao:'10–15 minutos de alongamentos simples.',progresso:0 },
      ],
      intermediario: [
        { id:'m1', nome:'Corrida 30 min',         icone:'🏃', descricao:'Corrida moderada.',         progresso:0 },
        { id:'m2', nome:'Treino funcional',       icone:'💪', descricao:'Força e resistência.',      progresso:0 },
        { id:'m3', nome:'Mobilidade',             icone:'🤸', descricao:'Mobilidade articular.',     progresso:0 },
      ],
      avancado: [
        { id:'a1', nome:'HIIT 25 min',            icone:'⚡', descricao:'Treino de alta intensidade.',progresso:0 },
        { id:'a2', nome:'Treino de força',        icone:'🏋️', descricao:'Séries com carga.',          progresso:0 },
        { id:'a3', nome:'Alongamento intenso',   icone:'🧘‍♀️',descricao:'Flexibilidade profunda.',   progresso:0 },
      ],
    };
    let tarefas = JSON.parse(JSON.stringify(baseTarefas[nivel] || baseTarefas.iniciante));

    function calcularSemanaPercent() {
      if (!tarefas.length) return 0;
      return Math.round((tarefas.filter(t => t.progresso === 100).length / tarefas.length) * 100);
    }
    function salvar() {
      localStorage.setItem('hs_diasAtivos',    String(diasAtivos));
      localStorage.setItem('hs_tarefas_' + nivel, JSON.stringify(tarefas));
    }
    function carregar() {
      const g = localStorage.getItem('hs_tarefas_' + nivel);
      if (g) try { const a = JSON.parse(g); if (Array.isArray(a) && a.length) tarefas = a; } catch(e) {}
      if (!localStorage.getItem('hs_diasAtivos')) diasAtivos = 1;
    }

    function abrirModal(idx) {
      const t = tarefas[idx]; if (!t) return;
      const m = document.getElementById('hs-user-modal');
      document.getElementById('hs-user-modal-title').textContent = t.nome;
      document.getElementById('hs-user-modal-desc').textContent  = t.descricao;
      document.getElementById('hs-user-modal-fill').style.width  = (t.progresso||0) + '%';
      document.getElementById('hs-user-modal-percent').textContent = (t.progresso||0) + '%';
      m.dataset.index = idx;
      m.classList.add('active');
      m.setAttribute('aria-hidden','false');
    }
    function fecharModal() {
      const m = document.getElementById('hs-user-modal');
      m.classList.remove('active');
      m.setAttribute('aria-hidden','true');
    }
    function concluir() {
      const m = document.getElementById('hs-user-modal');
      const i = Number(m.dataset.index);
      if (isNaN(i)) return;
      tarefas[i].progresso = 100;
      pontos += 10;
      semanaPercent = calcularSemanaPercent();
      salvar();
      fecharModal();
    }
    document.addEventListener('click', e => {
      if (e.target.id === 'hs-user-modal-close') { fecharModal(); return; }
      if (e.target.id === 'hs-user-modal-button') { concluir(); return; }
    });
    document.getElementById('hs-user-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) fecharModal();
    });
    document.addEventListener('DOMContentLoaded', () => { carregar(); });
  </script>
</body>
</html>
