<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Healthy Safely</title>
  <meta name="description" content="Dashboard do Healthy Safely - Acompanhe seu progresso em saúde e bem-estar." />
  <meta name="keywords" content="saúde, bem-estar, dashboard, tarefas, programas" />
  <meta property="og:title" content="Dashboard | Healthy Safely" />
  <meta property="og:description" content="Acompanhe seu progresso, programas e tarefas — tudo em um só lugar." />
  <meta property="og:image" content="/imagem/Logo repaginado 2.png" />
  <meta property="og:url" content="https://healthysafely.com/dashboard" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Healthy Safely" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/user/dashboard.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>
  <%- include('../partials/header.ejs') %>

  <!-- Flash message -->
  <% if (flash) { %>
  <aside id="flash-msg" class="hs-flash-msg" style="
    background:<%= flash.tipo==='sucesso' ? '#d1fae5' : flash.tipo==='erro' ? '#fee2e2' : '#dbeafe' %>;
    color:<%= flash.tipo==='sucesso' ? '#065f46' : flash.tipo==='erro' ? '#991b1b' : '#1e40af' %>;
    border:1px solid <%= flash.tipo==='sucesso' ? '#6ee7b7' : flash.tipo==='erro' ? '#fca5a5' : '#93c5fd' %>;" aria-live="polite">
    <%= flash.msg %>
  </aside>
  <% } %>

  <%
    const taskList = typeof tasks !== 'undefined' ? tasks : [];
    const tarefasHoje = taskList.filter(t => !t.completed).slice(0, 4);
  %>

  <main class="hs-main hs-main-spaced">
    <section class="hs-page-head card-base" aria-label="Boas-vindas">
      <section class="hs-page-head-copy">
        <span class="hs-page-kicker">
          Dashboard
        </span>
        <h1>Olá, <span><%= nome ? nome.split(' ')[0] : 'Usuário' %></span> </h1>
        <p>Acompanhe seu progresso, programas e tarefas — tudo em um só lugar.</p>
      </section>
    </section>

    <!-- ── PROGRAMAS ATIVOS ─────────────────────────────────── -->
    <section class="hs-tasks-section" aria-labelledby="tit-programas">
      <header class="hs-section-header">
        <h2 class="hs-section-title" id="tit-programas">
          Programas Ativos
        </h2>
        <a href="/programas" class="hs-section-link">Ver todos →</a>
      </header>

      <!-- CARD DO PROGRAMA -->
      <article class="hs-user-task-card programa-card-real">
        <!-- TOPO -->
        <header class="programa-topo">
          <div>
            <h3 class="hs-user-task-name" style="color: var(--accent-color)">
              Plano Alimentar
            </h3>
            <p class="programa-profissional">
              Criado por Nutricionista Ana
            </p>
          </div>
          <span class="programa-status">
            Ativo
          </span>
        </header>

        <!-- PROGRESSO -->
        <section class="programa-progresso">
          <div class="programa-progresso-info">
            <span>Progresso diário</span>
            <span id="programa-percentual">0%</span>
          </div>
          <div class="programa-barra">
            <div class="programa-fill" id="programa-fill"></div>
          </div>
        </section>

        <!-- ATIVIDADES -->
        <section class="programa-atividades">
          <p class="programa-subtitulo">
            Atividades de hoje
          </p>
          <div class="atividade-item" data-concluida="false">
            <div class="atividade-info">
              <span>- Beber 2L de água</span>
            </div>
            <button class="atividade-btn">
              Concluir
            </button>
          </div>
          <div class="atividade-item" data-concluida="false">
            <div class="atividade-info">
              <span>- Comer salada no almoço</span>
            </div>
            <button class="atividade-btn">
              Concluir
            </button>
          </div>
          <div class="atividade-item" data-concluida="false">
            <div class="atividade-info">
              <span>- Evitar refrigerante</span>
            </div>
            <button class="atividade-btn">
              Concluir
            </button>
          </div>
          <div class="atividade-item" data-concluida="false">
            <div class="atividade-info">
              <span>- Comer fruta à tarde</span>
            </div>
            <button class="atividade-btn">
              Concluir
            </button>
          </div>
        </section>

        <a href="/programas/1" class="hs-user-btn hs-user-btn-fullwidth">
          Ver plano completo
        </a>
      </article>
    </section>

    <!-- ── ATIVIDADES PESSOAIS DE HOJE ───────────────────────────────── -->
    <section class="hs-tasks-section" aria-labelledby="tit-hoje">
      <header class="hs-section-header">
        <h2 class="hs-section-title" id="tit-hoje">
          Atividades Pessoais de Hoje
        </h2>
        <a href="/tasks" class="hs-section-link">Ver todas →</a>
      </header>
      
      <% if (!tarefasHoje || !tarefasHoje.length) { %>
      <section class="hs-empty-state" aria-live="polite">
          <i class="bi bi-journal-plus" aria-hidden="true"></i>
          <p class="hs-empty-title">Nenhuma atividade pessoal hoje</p>
          <p class="hs-empty-subtitle">
            Adicione tarefas pessoais para acompanhar seu progresso diário.
          </p>
      </section>

      <% } else { %>
      <!-- TAREFAS PESSOAIS -->
      <main class="hs-pessoais-wrapper">
        <% tarefasHoje.forEach((t, i) => { %>
        <article class="hs-pessoal-card <%= t.completed ? 'concluida' : '' %>">
          <!-- ESQUERDA -->
          <div class="hs-pessoal-left">
            <div class="hs-pessoal-icon">
            </div>
            <div class="hs-pessoal-info">
              <p class="hs-pessoal-titulo">
                <%= t.title %>
              </p>
              <p class="hs-pessoal-meta">
                <i class="bi bi-tag"></i>
                <%= t.categoria || 'geral' %>
              </p>
            </div>
          </div>

          <!-- DIREITA -->
          <div class="hs-pessoal-right">
            <div class="hs-pessoal-progress-area">
              <div class="hs-pessoal-barra">
                <div class="hs-pessoal-fill"
                  style="width:<%= t.completed ? 100 : 0 %>%">
                </div>
              </div>
              <span class="hs-pessoal-percentual">
                <%= t.completed ? 100 : 0 %>%
              </span>
            </div>

            <% if (!t.completed) { %>
            <a href="/tasks/concluir?id=<%= t._id %>"
              class="hs-pessoal-btn">
              <i class="bi bi-check-circle"></i>
              Concluir
            </a>
            <% } else { %>
            <button class="hs-pessoal-btn" disabled>
              ✓ Concluída
            </button>
            <% } %>
          </div>
        </article>
        <% }) %>
      </main>
      <% } %>
    </section>

    <!-- ── ÁREAS DE SAÚDE ───────────────────────────────────── -->
    <section class="hs-tasks-section" aria-labelledby="tit-cats">
      <header class="hs-section-header">
        <h2 class="hs-section-title" id="tit-cats">
          Áreas de Saúde
        </h2>
      </header>
      <nav class="hs-categorias" aria-label="Categorias">
        <a href="/sono" class="hs-categoria-link">
          <img src="/imagem/sono.png" alt="" aria-hidden="true" />
          <span>Sono</span>
        </a>
        <a href="/saude-mental" class="hs-categoria-link">
          <img src="/imagem/saudemental.png" alt="" aria-hidden="true" />
          <span>Saúde Mental</span>
        </a>
        <a href="/atividade-fisica" class="hs-categoria-link">
          <img src="/imagem/atf.png" alt="" aria-hidden="true" />
          <span>Atividade Física</span>
        </a>
        <a href="/alimentacao" class="hs-categoria-link">
          <img src="/imagem/alimentacao.png" alt="" aria-hidden="true" />
          <span>Alimentação</span>
        </a>
      </nav>
    </section>
  </main>

  <!-- Modal -->
  <section class="hs-user-modal" id="hs-user-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <article class="hs-user-modal-content">
      <button class="hs-user-modal-close" id="hs-user-modal-close" aria-label="Fechar">&times;</button>
      <h2 id="hs-user-modal-title"></h2>
      <p id="hs-user-modal-desc"></p>
      <section class="hs-user-progress">
        <section class="progress-bar">
          <section class="fill" id="hs-user-modal-fill"></section>
        </section>
        <span class="percent-label" id="hs-user-modal-percent">0%</span>
      </section>
      <button class="hs-user-btn hs-user-modal-button" id="hs-user-modal-button">
        Marcar como Concluída
      </button>
    </article>
  </section>

  <%- include('../partials/footer.ejs') %>

  <script src="/js/dashboard.js"></script>
  <script src="/js/darkmode.js"></script>
</body>
</html>
