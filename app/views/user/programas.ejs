<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Programas | Healthy Safely</title>
    <meta name="description" content="Explore programas de saúde criados por profissionais para melhorar sua alimentação, sono, exercícios e bem-estar." />
    <meta name="keywords" content="programas de saúde, alimentação, sono, exercícios, saúde mental, bem-estar, Healthy Safely" />
    <meta property="og:title" content="Programas | Healthy Safely" />
    <meta property="og:description" content="Explore programas de saúde criados por profissionais para melhorar sua alimentação, sono, exercícios e bem-estar." />
    <meta property="og:image" content="/imagem/Logo repaginado 2.png" />
    <meta property="og:url" content="https://healthysafely.com/programas" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Healthy Safely" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/user/programas.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  </head>

  <body>
    <%- include('../partials/header.ejs') %>

    <main class="pg-programas">
      <!-- HERO -->
      <section class="programas-hero">
        <span class="programas-kicker"> Programas de Saúde </span>
        <h1>Encontre programas para melhorar sua rotina</h1>
        <p>
          Explore programas criados por profissionais para alimentação, sono,
          exercícios e saúde mental.
        </p>

        <a href="#lista-programas" class="programas-hero-btn">
          Explorar programas
        </a>
      </section>

      <!-- FILTROS -->
      <section class="programas-filtros" id="lista-programas">
        <button class="filtro-btn ativo">Todos</button>
        <button class="filtro-btn">Alimentação</button>
        <button class="filtro-btn">Sono</button>
        <button class="filtro-btn">Exercício</button>
        <button class="filtro-btn">Mental</button>
      </section>

      <!-- BARRA DE PESQUISA -->
      <section class="programas-search">
        <div class="search-container">
          <i class="bi bi-search"></i>
          <input type="text" class="search-input" placeholder="Buscar programas..." />
        </div>
      </section>

      <!-- LISTA -->
      <section class="programas-grid">
        <!-- CARD 1 -->
        <article class="programa-card">
          <div class="programa-card-topo">
            <span class="programa-tag"> Alimentação </span>

            <span class="programa-status"> Ativo </span>
          </div>

          <h3>Plano Alimentar Saudável</h3>

          <p class="programa-preco">R$ 49,90</p>

          <p class="programa-desc">
            Programa focado em melhorar hábitos alimentares com pequenas
            atividades diárias.
          </p>

          <div class="programa-meta">
            <span>
              <i class="bi bi-person"></i>
              Nutricionista Ana
            </span>

            <span>
              <i class="bi bi-calendar3"></i>
              7 dias
            </span>
          </div>

          <div class="programa-footer">
            <span class="programa-atividades"> 12 atividades </span>

            <a href="/programas-detalhes" class="programa-btn"> Ver programa </a>
          </div>
        </article>

        <!-- CARD -->
        <article class="programa-card">
          <div class="programa-card-topo">
            <span class="programa-tag"> Sono </span>
          </div>

          <h3>Sono de Qualidade</h3>

          <p class="programa-preco">R$ 39,90</p>

          <p class="programa-desc">
            Aprenda hábitos para melhorar seu descanso e dormir melhor.
          </p>

          <div class="programa-meta">
            <span>
              <i class="bi bi-person"></i>
              Especialista Bruno
            </span>

            <span>
              <i class="bi bi-calendar3"></i>
              14 dias
            </span>
          </div>

          <div class="programa-footer">
            <span class="programa-atividades"> 20 atividades </span>

            <a href="/programas/2" class="programa-btn"> Participar </a>
          </div>
        </article>

        <!-- CARD 3 -->
        <article class="programa-card">
          <div class="programa-card-topo">
            <span class="programa-tag"> Exercício </span>
          </div>

          <h3>Rotina Ativa</h3>

          <p class="programa-preco">R$ 44,90</p>

          <p class="programa-desc">
            Pequenos exercícios diários para sair do sedentarismo.
          </p>

          <div class="programa-meta">
            <span>
              <i class="bi bi-person"></i>
              Personal Lucas
            </span>

            <span>
              <i class="bi bi-calendar3"></i>
              10 dias
            </span>
          </div>

          <div class="programa-footer">
            <span class="programa-atividades"> 15 atividades </span>

            <a href="/programas/3" class="programa-btn"> Participar </a>
          </div>
        </article>
      </section>

      <!-- BENEFÍCIOS -->
      <section class="programas-beneficios">
        <h2>Por que participar?</h2>

        <div class="beneficios-grid">
          <article class="beneficio-card">
            <i class="bi bi-heart-pulse"></i>
            <h4>Hábitos saudáveis</h4>
            <p>Desenvolva uma rotina mais equilibrada.</p>
          </article>

          <article class="beneficio-card">
            <i class="bi bi-clipboard-check"></i>
            <h4>Atividades diárias</h4>
            <p>Conclua atividades simples todos os dias.</p>
          </article>

          <article class="beneficio-card">
            <i class="bi bi-person-check"></i>
            <h4>Criado por profissionais</h4>
            <p>Programas desenvolvidos por especialistas.</p>
          </article>
        </div>
      </section>
    </main>

    <%- include('../partials/footer.ejs') %>

  </body>
</html>
