<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Plano Alimentar Saudável | Healthy Safely</title>
    <meta name="description" content="Veja todos os detalhes do programa alimentar do Healthy Safely: objetivos, duração, atividades diárias, acompanhamento profissional e benefícios para sua saúde." />
    <meta name="keywords" content="plano alimentar, programa alimentar, alimentação saudável, nutrição, dieta saudável, bem-estar, Healthy Safely" />
    <meta property="og:title" content="Plano Alimentar Saudável | Healthy Safely" />
    <meta property="og:description" content="Conheça o programa alimentar do Healthy Safely com atividades diárias, acompanhamento profissional e hábitos saudáveis." />
    <meta property="og:image" content="/imagem/Logo repaginado 2.png" />
    <meta property="og:url" content="https://healthysafely.com/programas-detalhes" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Healthy Safely" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/user/programas-detalhes.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  </head>


  <body>
    <%- include('../partials/header.ejs') %>

    <main class="programa-detalhes" id="topo">
      <!-- HERO -->
      <%- include('../partials/botao-voltar.ejs') %>
      <section class="programa-hero">
        <span class="programa-categoria"> Alimentação </span>

        <h1>Plano Alimentar Saudável</h1>

        <p class="programa-preco">R$ 49,90</p>

        <p class="programa-descricao">
          Programa focado em melhorar hábitos alimentares através de pequenas
          atividades diárias.
        </p>

        <div class="programa-meta">
          <span>
            <i class="bi bi-person"></i>
            Nutricionista Ana
          </span>

          <span>
            <i class="bi bi-calendar3"></i>
            7 dias
          </span>

          <span>
            <i class="bi bi-list-check"></i>
            12 atividades
          </span>
        </div>

        <button class="programa-btn">Participar do programa</button>
      </section>

      <!-- BENEFÍCIOS -->
      <section class="programa-bloco">
        <h2>O que você irá desenvolver</h2>

        <div class="beneficios-grid">
          <article class="beneficio-item">Melhor hidratação</article>

          <article class="beneficio-item">Alimentação equilibrada</article>

          <article class="beneficio-item">Mais disposição</article>

          <article class="beneficio-item">Hábitos saudáveis</article>
        </div>
      </section>

      <!-- CRONOGRAMA -->
      <section class="programa-bloco">
        <h2>Cronograma do programa</h2>

        <div class="cronograma">
          <!-- DIA -->
          <article class="dia-card">
            <div class="dia-topo">
              <h3>Dia 1</h3>

              <span> Introdução </span>
            </div>

            <ul>
              <li>Beber 2L de água</li>

              <li>Comer salada no almoço</li>

              <li>Evitar refrigerante</li>
            </ul>
          </article>

          <!-- DIA -->
          <article class="dia-card">
            <div class="dia-topo">
              <h3>Dia 2</h3>

              <span> Alimentação natural </span>
            </div>

            <ul>
              <li>Comer fruta à tarde</li>

              <li>Comer legumes no jantar</li>

              <li>Continuar hidratação</li>
            </ul>
          </article>

          <!-- DIA -->
          <article class="dia-card">
            <div class="dia-topo">
              <h3>Dia 3</h3>

              <span> Redução de açúcar </span>
            </div>

            <ul>
              <li>Evitar doces industrializados</li>

              <li>Substituir lanche por fruta</li>

              <li>Beber água ao acordar</li>
            </ul>
          </article>

          <!-- DIA -->
          <article class="dia-card">
            <div class="dia-topo">
              <h3>Dia 4</h3>

              <span> Organização alimentar </span>
            </div>

            <ul>
              <li>Planejar refeições</li>

              <li>Comer verduras no almoço</li>

              <li>Manter hidratação</li>
            </ul>
          </article>
        </div>
      </section>

      <!-- COMO FUNCIONA -->
      <section class="programa-bloco">
        <h2>Como funciona</h2>

        <div class="funciona-grid">
          <article class="funciona-item">
            <span> 1 </span>

            <h4>Entre no programa</h4>

            <p>Comece sua jornada de saúde.</p>
          </article>

          <article class="funciona-item">
            <span> 2 </span>

            <h4>Complete atividades</h4>

            <p>Realize pequenas tarefas diárias.</p>
          </article>

          <article class="funciona-item">
            <span> 3 </span>

            <h4>Acompanhe progresso</h4>

            <p>Veja evolução no dashboard.</p>
          </article>
        </div>
      </section>

      <%- include('../partials/voltar-topo.ejs') %>
    </main>

    <%- include('../partials/footer.ejs') %>

  </body>
</html>
