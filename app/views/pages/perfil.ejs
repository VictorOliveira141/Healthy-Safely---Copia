<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perfil | Healthy Safely</title>
  <meta name="description" content="Visualize e edite seu perfil no Healthy Safely" />
  <meta name="keywords" content="perfil, usuário, saúde, bem-estar" />
  <meta property="og:title" content="Perfil | Healthy Safely" />
  <meta property="og:description" content="Acesse seu perfil e gerencie suas informações pessoais no Healthy Safely." />
  <meta property="og:image" content="/imagem/Logo repaginado 2.png" />
  <meta property="og:url" content="https://healthysafely.com/perfil" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Healthy Safely" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/perfil.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>
  <%- include('../partials/header.ejs') %>
  <%
    const configHref = usuario && usuario.tipo === "profissional"
      ? "/profissional/configuracoes"
      : "/configuracoes";
  %>

  <main class="perfil-corpo" style="padding-bottom:6rem">
    <!-- Banner perfil -->
    <section class="perfil" aria-labelledby="perfil-nome">
      <figure class="foto-perfil">
        <img
          src="<%= usuario && usuario.foto_perfil ? usuario.foto_perfil : '/imagem/user.png' %>"
          alt="Foto de perfil"
        />
        <label for="uploadFoto" class="camera-icon" title="Alterar foto">
          <i class="bi bi-camera-fill" aria-hidden="true"></i>
        </label>
        <input type="file" id="uploadFoto" accept="image/*" hidden />
      </figure>

      <section class="info-perfil" style="position:relative">
        <p class="seguidores">
        <span>Seu perfil</span>
        </p>
        <h1 id="perfil-nome">
          <%= usuario && usuario.nome ? usuario.nome.split(' ').slice(0,2).join(' ') : 'Usuário' %>
        </h1>
        <h2>@<%= usuario && usuario.nomeusuario ? usuario.nomeusuario : '—' %></h2>
      </section>
    </section>

    <!-- Ações rápidas -->
    <section class="containers-gerais" aria-labelledby="sec-acoes">
      <h2 class="containers-gerais-titulo" id="sec-acoes">Acesso Rápido</h2>
      <nav class="item-container" aria-label="Ações do perfil">
        <a href="/tasks"><i data-lucide="clipboard-check"></i> Minhas Tarefas</a>
        <a href="/programas"><i data-lucide="layout-grid"></i> Programas</a>
        <a href="/historico"><i data-lucide="bar-chart-3"></i> Histórico</a>
        <a href="/notificacoes"><i data-lucide="bell"></i> Notificações</a>
        <a href="<%= configHref %>"><i data-lucide="settings"></i> Configurações</a>
        <a href="/privacidade"><i data-lucide="shield"></i> Privacidade</a>
        <a href="/ajuda"><i data-lucide="help-circle"></i> Ajuda</a>
        <a href="/sair" style="color:#dc2626">
          <i data-lucide="log-out" style="color:#dc2626"></i> Sair da conta
        </a>
      </nav>
    </section>

  </main>

  <%- include('../partials/footer.ejs') %>
</body>
</html>
