<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Healthy Safely - Inicio</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../css/tomarammeutela.css" />
    <link rel="stylesheet" href="../css/global.css" />
    <link rel="icon" href="../imagem/Logo repaginado 2.png" />
  </head>

  <body id="topo">
    <%- include('../partials/header.ejs') %>

    <main>
      <section class="main-topo">
        <section class="carrossel">
          <article class="carrossel-slide active">
            <img src="../imagem/bannerzaodeacessoo.PNG" alt="Banner 1" />
          </article>

          <article class="carrossel-slide">
            <img src="../imagem/1x/bannerprogresso.png" alt="Banner 2" />
          </article>

          <button class="botao-prev">&#10094;</button>
          <button class="botao-next">&#10095;</button>
        </section>

        <!-- LATERAL -->
        <aside class="side-content">
          <article class="side-item">
            <img src="../imagem/confira.png" class="bannerof" />
          </article>

          <article class="side-item">
            <img src="../imagem/a (34).png" class="bannerof" />
          </article>
        </aside>
      </section>

      <!-- TIPO DE CONTA -->
      <section class="centro">
        <h2>ESCOLHA SEU TIPO DE CONTA</h2>

        <section class="escolher-container">
          <article class="escolher-card" tabindex="0">
            <article class="card-inner">
              <div class="card-front">
                <img src="../imagem/a (48).png" class="escolher-img" />
              </div>

              <div class="card-back">
                <p>
                  Conta para profissionais: Ideal para educadores físicos...
                </p>
                <button class="btn-criar" data-target="/cadastroProfissional">
                  Criar conta
                </button>
              </div>
            </article>
          </article>

          <article class="escolher-card" tabindex="0">
            <article class="card-inner">
              <div class="card-front">
                <img src="../imagem/a (49).png" class="escolher-img" />
              </div>

              <div class="card-back">
                <p>Conta para usuários: Perfeita para quem quer melhorar...</p>
                <button class="btn-criar" data-target="/cadastroCliente">
                  Criar conta
                </button>
              </div>
            </article>
          </article>
        </section>
      </section>

      <!-- COMO FUNCIONA -->
      <section class="centro">
        <h2>COMO O SISTEMA FUNCIONA?</h2>

        <section class="steps">
          <section class="steps-container">
            <section class="step">
              <span>1</span>
              <p>Crie sua conta</p>
            </section>

            <section class="step">
              <span>2</span>
              <p>Conecte-se com um profissional</p>
            </section>

            <section class="step">
              <span>3</span>
              <p>Acompanhe sua evolução</p>
            </section>
          </section>
        </section>
      </section>

      <!-- SUGESTÕES -->
      <section class="centro">
        <h2>SUGESTÕES DE TAREFAS</h2>

        <section class="grade-tarefas">
          <article class="cartao-tarefas" aria-labelledby="tarefa-corrida">
            <h3 id="tarefa-corrida">
              <span aria-hidden="true">🏃‍♂️</span> Corra!
            </h3>

            <p>Caminhe um total de 10km em 1 semana</p>
            <p>
              Dificuldade:
              <span aria-label="Dificuldade: Fácil" class="facil">Fácil</span>
            </p>
            <p>Duração: <span aria-label="Duração: 1 semana">1 semana</span></p>
            <p>XP: <span aria-label="XP: 300" class="xp">300</span></p>

            <button
              class="botao-tarefas"
              type="button"
              aria-label="Iniciar tarefa Corra"
            >
              Iniciar
            </button>
          </article>

          <article class="cartao-tarefas" aria-labelledby="tarefa-alimentacao">
            <h3 id="tarefa-alimentacao">
              <span aria-hidden="true">🥗</span> Alimentação Saudável
            </h3>

            <p>Coma 2 frutas diariamente</p>
            <p>
              Dificuldade:
              <span aria-label="Dificuldade: Fácil" class="medio">Médio</span>
            </p>
            <p>Duração: <span aria-label="Duração: 1 semana">1 semana</span></p>
            <p>XP: <span aria-label="XP: 300" class="xp">400</span></p>

            <button
              class="botao-tarefas"
              type="button"
              aria-label="Iniciar tarefa Alimentação Saudável"
            >
              Iniciar
            </button>
          </article>

          <article class="cartao-tarefas" aria-labelledby="tarefa-familia">
            <h3 id="tarefa-familia">
              <span aria-hidden="true">📚</span> FOCO TOTAL!
            </h3>

            <p>Estude 2h por dia sem interrupções por 1 semana</p>
            <p>
              Dificuldade:
              <span aria-label="Dificuldade: Fácil" class="dificil"
                >Difícil</span
              >
            </p>
            <p>Duração: <span aria-label="Duração: 1 semana">1 semana</span></p>
            <p>
              XP: <span aria-label="XP: 300" class="xp">500 + Medalha</span>
            </p>
            <button
              class="botao-tarefas"
              type="button"
              aria-label="Iniciar tarefa FOCO TOTAL!"
            >
              Iniciar
            </button>
          </article>

          <article class="ver-mais">
            <h3>Ver mais tarefas</h3>
            <button onclick="window.location.href = '/#'" class="btn-circular">
              +
            </button>
          </article>
        </section>
      </section>

      <!-- VOLTAR -->
      <section class="voltar-topo">
        <a href="#topo"><h1>Voltar ao topo</h1></a>
      </section>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script src="../js/carrossel-tomarammeutela.js"></script>
    <script src="../js/slider-tomarammeutela.js"></script>
    <script>
      // Flip card: toggle .is-flipped on click; button stops propagation and navigates
      (function () {
        const cards = document.querySelectorAll(".escolher-card");
        cards.forEach((card) => {
          card.addEventListener("click", () =>
            card.classList.toggle("is-flipped"),
          );
          card.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              card.classList.toggle("is-flipped");
            }
          });
        });

        const buttons = document.querySelectorAll(".escolher-card .btn-criar");
        buttons.forEach((btn) => {
          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const tgt = btn.getAttribute("data-target") || "#";
            if (tgt && tgt !== "#") window.location.href = tgt;
          });
        });
      })();
    </script>
  </body>
</html>
