<!DOCTYPE html>
<html lang="pt-br">
<head>
  <script src="/js/darkmode.js"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Início | Healthy Safely</title>
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/tomarammeutela.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
</head>
<body>
  <%- include('../partials/header.ejs') %>

  <main>
    <!-- ── HERO ─────────────────────────────────────────── -->
    <section class="lp-hero" aria-labelledby="lp-hero-titulo">
      <section class="lp-hero-content">
        <span class="lp-badge"><i class="bi bi-lightning-fill"></i> Plataforma de Hábitos #1</span>
        <h1 id="lp-hero-titulo">
          Transforme seus hábitos.<br>
          <span class="lp-destaque">Meça sua evolução.</span>
        </h1>
        <p class="lp-hero-desc">
          O Healthy Safely é um sistema de monitoramento de hábitos que mede
          sua consistência, calcula pontuação e conecta você a profissionais de saúde.
        </p>
        <nav class="lp-hero-btns" aria-label="Ações principais">
          <a href="/cadastro" class="btn-primary">
            <i class="bi bi-person-plus-fill"></i> Criar conta grátis
          </a>
          <a href="#como-funciona" class="btn-outline">
            <i class="bi bi-play-circle"></i> Como funciona
          </a>
        </nav>
        <section class="lp-hero-stats" aria-label="Números da plataforma">
          <article>
            <strong>500+</strong>
            <span>Usuários ativos</span>
          </article>
          <article>
            <strong>12k+</strong>
            <span>Tarefas concluídas</span>
          </article>
          <article>
            <strong>98%</strong>
            <span>Satisfação</span>
          </article>
        </section>
      </section>
      <figure class="lp-hero-img" aria-hidden="true">
        <!-- ESPAÇO PARA IMAGEM DO HERO -->
        <section class="img-placeholder">
          <i class="bi bi-image" style="font-size:3rem;opacity:.3"></i>
          <span>Imagem do app / mockup</span>
        </section>
      </figure>
    </section>

    <!-- ── COMO FUNCIONA ─────────────────────────────────── -->
    <section class="lp-section lp-como" id="como-funciona" aria-labelledby="lp-como-titulo">
      <header class="lp-section-header">
        <span class="lp-section-tag">Funcionalidades</span>
        <h2 id="lp-como-titulo">Como o Healthy Safely funciona?</h2>
        <p>Um sistema completo de progressão baseado em dados reais do seu comportamento.</p>
      </header>

      <section class="lp-steps">
        <article class="lp-step">
          <figure class="lp-step-num">1</figure>
          <h3>Registre suas tarefas</h3>
          <p>Crie tarefas personalizadas de saúde: sono, alimentação, exercícios e mais.</p>
        </article>
        <article class="lp-step">
          <figure class="lp-step-num">2</figure>
          <h3>Complete e ganhe pontos</h3>
          <p>Cada tarefa concluída gera pontos. Mantenha a consistência e suba de nível.</p>
        </article>
        <article class="lp-step">
          <figure class="lp-step-num">3</figure>
          <h3>Acompanhe sua evolução</h3>
          <p>Veja gráficos de constância semanal, histórico detalhado e medalhas conquistadas.</p>
        </article>
        <article class="lp-step">
          <figure class="lp-step-num">4</figure>
          <h3>Receba feedback profissional</h3>
          <p>Conecte-se a um profissional que analisa seus dados e envia orientações personalizadas.</p>
        </article>
      </section>
    </section>

    <!-- ── PARA QUEM? ─────────────────────────────────────── -->
    <section class="lp-section lp-perfis" id="perfis" aria-labelledby="lp-perfis-titulo">
      <header class="lp-section-header">
        <span class="lp-section-tag">Perfis</span>
        <h2 id="lp-perfis-titulo">Escolha seu tipo de conta</h2>
      </header>

      <section class="lp-cards-perfil">
        <article class="lp-perfil-card" tabindex="0">
          <figure class="lp-perfil-img">
            <!-- ESPAÇO PARA IMAGEM DO USUÁRIO -->
            <section class="img-placeholder small">
              <i class="bi bi-person-fill"></i>
              <span>Imagem usuário</span>
            </section>
          </figure>
          <section class="lp-perfil-body">
            <span class="badge badge-green">👤 Usuário</span>
            <h3>Quero monitorar minha saúde</h3>
            <p>Registre tarefas, acompanhe seu progresso, conquiste medalhas e mantenha a consistência dos seus hábitos.</p>
            <ul class="lp-lista-feat">
              <li><i class="bi bi-check-circle-fill"></i> Tarefas diárias e semanais</li>
              <li><i class="bi bi-check-circle-fill"></i> Sistema de pontos e níveis</li>
              <li><i class="bi bi-check-circle-fill"></i> Medalhas por constância</li>
              <li><i class="bi bi-check-circle-fill"></i> Acompanhamento profissional</li>
            </ul>
            <a href="/cadastroCliente" class="btn-primary" style="width:100%;justify-content:center;margin-top:1rem">
              Criar conta de usuário
            </a>
          </section>
        </article>

        <article class="lp-perfil-card destaque" tabindex="0">
          <span class="lp-perfil-badge-top">⭐ Para profissionais</span>
          <figure class="lp-perfil-img">
            <!-- ESPAÇO PARA IMAGEM DO PROFISSIONAL -->
            <section class="img-placeholder small">
              <i class="bi bi-briefcase-fill"></i>
              <span>Imagem profissional</span>
            </section>
          </figure>
          <section class="lp-perfil-body">
            <span class="badge badge-blue">🩺 Profissional</span>
            <h3>Quero acompanhar pacientes</h3>
            <p>Acesse métricas detalhadas dos seus pacientes, analise desempenho e envie feedback baseado em dados reais.</p>
            <ul class="lp-lista-feat">
              <li><i class="bi bi-check-circle-fill"></i> Painel de pacientes</li>
              <li><i class="bi bi-check-circle-fill"></i> Métricas de constância</li>
              <li><i class="bi bi-check-circle-fill"></i> Histórico de tarefas</li>
              <li><i class="bi bi-check-circle-fill"></i> Envio de feedback</li>
            </ul>
            <a href="/cadastroProfissional" class="btn-primary" style="width:100%;justify-content:center;margin-top:1rem">
              Criar conta profissional
            </a>
          </section>
        </article>
      </section>
    </section>

    <!-- ── SISTEMA DE PROGRESSÃO ──────────────────────────── -->
    <section class="lp-section lp-progressao" aria-labelledby="lp-prog-titulo">
      <header class="lp-section-header">
        <span class="lp-section-tag">Gamificação</span>
        <h2 id="lp-prog-titulo">Sistema de progressão</h2>
        <p>Não é um checklist. É um sistema que interpreta seu comportamento e recompensa sua evolução.</p>
      </header>

      <section class="lp-niveis-grid">
        <article class="lp-nivel-card">
          <figure class="lp-nivel-icon">🌱</figure>
          <h3>Iniciante</h3>
          <p class="lp-nivel-pts">0 – 100 pts</p>
          <p>Você está começando sua jornada de hábitos saudáveis.</p>
        </article>
        <article class="lp-nivel-card">
          <figure class="lp-nivel-icon">📈</figure>
          <h3>Em Evolução</h3>
          <p class="lp-nivel-pts">101 – 300 pts</p>
          <p>Sua consistência já está aparecendo nos dados.</p>
        </article>
        <article class="lp-nivel-card ativo">
          <figure class="lp-nivel-icon">⚡</figure>
          <h3>Consistente</h3>
          <p class="lp-nivel-pts">301 – 600 pts</p>
          <p>Hábito consolidado. Seu progresso é notável.</p>
        </article>
        <article class="lp-nivel-card">
          <figure class="lp-nivel-icon">🏆</figure>
          <h3>Alto Desempenho</h3>
          <p class="lp-nivel-pts">601+ pts</p>
          <p>Elite da plataforma. Exemplo de consistência.</p>
        </article>
      </section>

      <section class="lp-medalhas" aria-label="Medalhas do sistema">
        <h3>Medalhas que você pode conquistar</h3>
        <section class="lp-medalhas-grid">
          <article class="lp-medalha"><span>🥉</span><strong>Bronze</strong><small>7 dias seguidos</small></article>
          <article class="lp-medalha"><span>🥈</span><strong>Prata</strong><small>15 dias 80%+</small></article>
          <article class="lp-medalha"><span>🥇</span><strong>Ouro</strong><small>30 dias de constância</small></article>
          <article class="lp-medalha"><span>📈</span><strong>Superação</strong><small>Melhorou vs semana ant.</small></article>
          <article class="lp-medalha"><span>🔥</span><strong>Persistência</strong><small>Voltou após pausa</small></article>
          <article class="lp-medalha"><span>⚖️</span><strong>Equilíbrio</strong><small>Tarefas distribuídas</small></article>
        </section>
      </section>
    </section>

    <!-- ── PLANOS ─────────────────────────────────────────── -->
    <section class="lp-section lp-planos" id="planos" aria-labelledby="lp-planos-titulo">
      <header class="lp-section-header">
        <span class="lp-section-tag">Planos</span>
        <h2 id="lp-planos-titulo">Nossos planos</h2>
        <p>Comece grátis. Evolua conforme sua necessidade.</p>
      </header>

      <section class="lp-planos-grid">
        <article class="lp-plano-card">
          <header class="lp-plano-header">
            <span class="lp-plano-tipo">Gratuito</span>
            <p class="lp-plano-preco">R$ 0<span>/mês</span></p>
          </header>
          <ul class="lp-plano-lista">
            <li><i class="bi bi-check-lg"></i> Registro de tarefas</li>
            <li><i class="bi bi-check-lg"></i> Sistema de pontos</li>
            <li><i class="bi bi-check-lg"></i> Níveis de progressão</li>
            <li><i class="bi bi-check-lg"></i> Histórico básico</li>
            <li class="off"><i class="bi bi-x-lg"></i> Relatórios avançados</li>
            <li class="off"><i class="bi bi-x-lg"></i> Acompanhamento profissional</li>
          </ul>
          <a href="/cadastroCliente" class="btn-outline" style="width:100%;justify-content:center">Começar grátis</a>
        </article>

        <article class="lp-plano-card destaque">
          <span class="lp-plano-top-badge">Mais popular</span>
          <header class="lp-plano-header">
            <span class="lp-plano-tipo">Premium</span>
            <p class="lp-plano-preco">R$ 19,90<span>/mês</span></p>
            <small>7 dias grátis para testar</small>
          </header>
          <ul class="lp-plano-lista">
            <li><i class="bi bi-check-lg"></i> Tudo do plano gratuito</li>
            <li><i class="bi bi-check-lg"></i> Relatórios avançados</li>
            <li><i class="bi bi-check-lg"></i> Gráfico de evolução</li>
            <li><i class="bi bi-check-lg"></i> Análise de constância</li>
            <li><i class="bi bi-check-lg"></i> 1 acompanhamento/mês</li>
            <li><i class="bi bi-check-lg"></i> Feedback profissional</li>
          </ul>
          <a href="/cadastroCliente" class="btn-primary" style="width:100%;justify-content:center">Assinar Premium</a>
        </article>

        <article class="lp-plano-card">
          <header class="lp-plano-header">
            <span class="lp-plano-tipo">Profissional</span>
            <p class="lp-plano-preco">R$ 49,90<span>/mês</span></p>
          </header>
          <ul class="lp-plano-lista">
            <li><i class="bi bi-check-lg"></i> Painel de pacientes</li>
            <li><i class="bi bi-check-lg"></i> Métricas comparativas</li>
            <li><i class="bi bi-check-lg"></i> Histórico detalhado</li>
            <li><i class="bi bi-check-lg"></i> Envio de feedback</li>
            <li><i class="bi bi-check-lg"></i> Relatórios por usuário</li>
            <li><i class="bi bi-check-lg"></i> Suporte prioritário</li>
          </ul>
          <a href="/cadastroProfissional" class="btn-outline" style="width:100%;justify-content:center">Assinar Profissional</a>
        </article>
      </section>
    </section>

    <!-- ── CTA FINAL ──────────────────────────────────────── -->
    <section class="lp-cta" aria-labelledby="lp-cta-titulo">
      <h2 id="lp-cta-titulo">Pronto para transformar seus hábitos?</h2>
      <p>Crie sua conta gratuita em menos de 2 minutos e comece hoje.</p>
      <a href="/cadastro" class="btn-primary" style="font-size:1.1rem;padding:1rem 2.5rem">
        <i class="bi bi-rocket-takeoff-fill"></i> Começar agora
      </a>
    </section>
  </main>

  <%- include('../partials/footer.ejs') %>
  <script src="/js/carrossel-tomarammeutela.js"></script>
</body>
</html>
