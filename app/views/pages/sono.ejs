<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sono | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/pagina-tarefa.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
      .sono-form-card { background: var(--surface-card, var(--primary-color)); border: 1px solid var(--border); border-radius: 16px; padding: 1.25rem; margin: 1.5rem auto; max-width: 500px; }
      .sono-form-card h2 { font-size: 1rem; font-weight: 800; color: var(--fundoclaro); margin-bottom: .75rem; }
      .sono-form-row { display: flex; gap: .75rem; align-items: center; flex-wrap: wrap; margin-bottom: .6rem; }
      .sono-form-row label { font-size: .82rem; color: var(--muted); font-weight: 600; min-width: 130px; }
      .sono-form-row input, .sono-form-row select { flex: 1; padding: .5rem .75rem; border: 1.5px solid var(--border); border-radius: 8px; font-size: .88rem; color: var(--fundoclaro); background: var(--primary-color); min-width: 100px; }
      .sono-form-row input:focus, .sono-form-row select:focus { outline: none; border-color: #1a8a75; }
      .btn-sono { padding: .55rem 1.25rem; background: #1a8a75; color: #fff; border: none; border-radius: 10px; font-family: inherit; font-size: .88rem; font-weight: 700; cursor: pointer; margin-top: .25rem; transition: opacity .15s; }
      .btn-sono:hover { opacity: .85; }
      .sono-historico { max-width: 500px; margin: 0 auto 2rem; }
      .sono-historico h2 { font-size: .95rem; font-weight: 800; color: var(--fundoclaro); margin-bottom: .6rem; }
      .sono-item { display: flex; align-items: center; justify-content: space-between; padding: .5rem .75rem; background: var(--surface-card, var(--primary-color)); border: 1px solid var(--border); border-radius: 10px; margin-bottom: .4rem; font-size: .82rem; }
      .sono-item-data { color: var(--muted); }
      .sono-item-horas { font-weight: 800; color: var(--fundoclaro); }
      .sono-item-qual { font-size: .72rem; padding: 2px 8px; border-radius: 20px; font-weight: 700; }
      .qual-5 { background: #d1fae5; color: #065f46; }
      .qual-4 { background: #dbeafe; color: #1e40af; }
      .qual-3 { background: #fef3c7; color: #92400e; }
      .qual-2, .qual-1 { background: #fee2e2; color: #991b1b; }
    </style>
  </head>
  <body>
    <%- include('../partials/header.ejs') %>

    <main class="pt-page">
      <div class="pt-hero" aria-hidden="true"></div>

      <!-- Card principal -->
      <div class="pt-card-wrap">
        <section class="pt-card" aria-labelledby="titulo-sono">
          <header class="pt-card-topo">
            <img src="/imagem/lua.png" alt="Ícone de sono" />
            <h1 id="titulo-sono">Sono de Qualidade</h1>
          </header>

          <div class="pt-card-corpo">
            <p class="pt-card-texto">
              Durma pelo menos entre 8 a 9 horas por uma semana e escreva os
              resultados.<br />
              Algum profissional irá atender seu relatório.
            </p>
          </div>

          <footer class="pt-card-rodape">
            <div class="pt-progresso-bloco">
              <span
                class="pt-porcentagem-texto"
                id="porcTexto"
                aria-live="polite"
                >0% concluída</span
              >
              <div
                class="pt-barra-track"
                role="progressbar"
                aria-valuenow="0"
                aria-valuemin="0"
                aria-valuemax="100"
                id="barraTrack"
              >
                <div class="pt-barra-fill" id="barraFill"></div>
              </div>
            </div>
            <button
              class="pt-botao"
              id="btnAcao"
              type="button"
              onclick="registrar()"
            >
              Iniciar
            </button>
          </footer>
        </section>
      </div>

      <!-- Dicas -->
      <section class="pt-secao" aria-labelledby="titulo-dicas-sono">
        <h2 class="pt-secao-titulo" id="titulo-dicas-sono">
          Dicas para dormir melhor
        </h2>
        <div class="pt-grid">
          <article class="pt-grid-card">
            <i class="bi bi-moon-stars-fill" aria-hidden="true"></i>
            <h4>Horário fixo</h4>
            <p>
              Durma e acorde sempre no mesmo horário, inclusive nos fins de
              semana.
            </p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-thermometer-low" aria-hidden="true"></i>
            <h4>Ambiente fresco</h4>
            <p>
              Um quarto com temperatura entre 18°C e 22°C favorece o sono
              profundo.
            </p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-phone-landscape" aria-hidden="true"></i>
            <h4>Sem telas</h4>
            <p>
              Evite celular, TV e computador pelo menos 30 minutos antes de
              dormir.
            </p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-cup-hot-fill" aria-hidden="true"></i>
            <h4>Chá relaxante</h4>
            <p>
              Camomila, erva-doce ou melissa ajudam o corpo a relaxar antes do
              sono.
            </p>
          </article>
        </div>
      </section>

      <!-- Navegação entre categorias -->
      <nav
        class="pt-nav-tarefas"
        aria-label="Navegar entre categorias de saúde"
      >
        <h2 class="pt-nav-titulo">Suas tarefas</h2>
        <div class="pt-nav-grid">
          <a href="/sono" class="pt-nav-item ativo" aria-current="page"
            ><img src="/imagem/sono.png" alt="Sono" /><span>Sono</span></a
          >
          <a href="/saude-mental" class="pt-nav-item"
            ><img src="/imagem/saudemental.png" alt="Saúde Mental" /><span
              >Saúde Mental</span
            ></a
          >
          <a href="/atividade-fisica" class="pt-nav-item"
            ><img src="/imagem/atf.png" alt="Atividade Física" /><span
              >Atividade</span
            ></a
          >
          <a href="/alimentacao" class="pt-nav-item"
            ><img src="/imagem/alimentacao.png" alt="Alimentação" /><span
              >Alimentação</span
            ></a
          >
          <a href="#" class="pt-nav-outros"
            ><img src="/imagem/outros.png" alt="Outros" /><span>Outros</span></a
          >
        </div>
      </nav>
    </main>

    <%- include('../partials/footer.ejs') %>

    <!-- Flash message -->
    <% if (typeof flash !== 'undefined' && flash) { %>
    <div id="flash-sono" style="position:fixed;top:1rem;left:50%;transform:translateX(-50%);z-index:9999;padding:.75rem 1.5rem;border-radius:12px;font-weight:700;font-size:.9rem;box-shadow:0 4px 20px rgba(0,0,0,.15);background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;">
      <%= flash.msg %>
    </div>
    <script>setTimeout(()=>{const el=document.getElementById('flash-sono');if(el)el.remove();},3500);</script>
    <% } %>

    <!-- Formulário de registro de sono -->
    <section class="sono-form-card">
      <h2><i class="bi bi-moon-stars-fill" style="color:#1a8a75"></i> Registrar sono de hoje</h2>
      <form action="/sono/registrar" method="POST">
        <div class="sono-form-row">
          <label for="horas">Horas dormidas</label>
          <input type="number" id="horas" name="horas_dormidas" min="0" max="24" step="0.5" placeholder="Ex: 7.5" required />
        </div>
        <div class="sono-form-row">
          <label for="qualidade">Qualidade do sono</label>
          <select id="qualidade" name="qualidade">
            <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
            <option value="4">⭐⭐⭐⭐ Boa</option>
            <option value="3" selected>⭐⭐⭐ Regular</option>
            <option value="2">⭐⭐ Ruim</option>
            <option value="1">⭐ Péssima</option>
          </select>
        </div>
        <button type="submit" class="btn-sono"><i class="bi bi-save-fill"></i> Salvar registro</button>
      </form>
    </section>

    <!-- Histórico de sono -->
    <% if (typeof registros !== 'undefined' && registros && registros.length) { %>
    <section class="sono-historico">
      <h2>Últimos registros</h2>
      <% registros.forEach(r => { %>
      <article class="sono-item">
        <span class="sono-item-data"><%= new Date(r.data + 'T12:00:00').toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'2-digit'}) %></span>
        <span class="sono-item-horas"><i class="bi bi-moon-fill" style="color:#6366f1"></i> <%= r.horas_dormidas %>h</span>
        <span class="sono-item-qual qual-<%= r.qualidade %>"><%= ['','Péssima','Ruim','Regular','Boa','Excelente'][r.qualidade] %></span>
      </article>
      <% }) %>
    </section>
    <% } %>

    <script>
      // Script de progresso local mantido por compatibilidade
      const CHAVE = "hs_sono_prog";
      let progresso = Number(localStorage.getItem(CHAVE) || 0);
      const btn = document.getElementById("btnAcao");
      const porcTexto = document.getElementById("porcTexto");
      const fill = document.getElementById("barraFill");
      const track = document.getElementById("barraTrack");

      function renderProgresso() {
        if (!fill) return;
        fill.style.width = progresso + "%";
        if (porcTexto) porcTexto.textContent = progresso + "% concluída";
        if (track) track.setAttribute("aria-valuenow", progresso);
        if (progresso >= 100 && btn) { btn.textContent = "✓ Concluída!"; btn.disabled = true; }
      }

      function registrar() {
        if (progresso >= 100) return;
        progresso = Math.min(progresso + 14, 100);
        localStorage.setItem(CHAVE, progresso);
        renderProgresso();
        if (progresso < 100 && btn) btn.textContent = "Registrar próxima noite";
      }

      renderProgresso();
    </script>
  </body>
</html>
