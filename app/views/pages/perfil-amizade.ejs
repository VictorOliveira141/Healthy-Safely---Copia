<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <script src="/js/darkmode.js"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta
  name="description"
  content="Veja o perfil da sua amizade no Healthy Safely: acompanhe informações, atividades e interaja com seus amigos na plataforma."
/>
  <title>Perfil de Kauã | Healthy Safely</title>
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/perfil.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>
<body>
  <%- include('../partials/header.ejs') %>

  <main class="perfil-corpo" style="padding-bottom:6rem">

    <!-- Banner perfil -->
    <section class="perfil" aria-labelledby="perfil-nome">
      <%- include('../partials/botao-voltar.ejs') %>
      <style></style>
      <figure class="foto-perfil">
        <img
          src="<%= usuario && usuario.foto_perfil ? usuario.foto_perfil : '/imagem/user.png' %>"
          alt="Foto de perfil"
        />
        
        <input type="file" id="uploadFoto" accept="image/*" hidden />
      </figure>

      <section class="info-perfil" style="position:relative">
        <h1 id="perfil-nome">
          Kauã Mauricio
        </h1>
        <h2>@Mauricio</h2>
        <p class="seguidores">
          <span><i class="bi bi-people-fill"></i> <%= usuario && usuario.seguidores || 0 %> seguidores</span>
          <span><i class="bi bi-person-check-fill"></i> <%= usuario && usuario.seguindo || 0 %> seguindo</span>
        </p>
      </section>
    </section>

    <!-- Nível -->
    <section class="containers-gerais" aria-labelledby="sec-nivel">
      <h2 class="containers-gerais-titulo" id="sec-nivel">Nível Atual</h2>
      <section class="rank-info">
        <span class="rank-atual">
          <i class="bi bi-star-fill" style="color:#f59e0b"></i>
          <%= usuario && usuario.nivel ? usuario.nivel.charAt(0).toUpperCase() + usuario.nivel.slice(1) : 'Iniciante' %>
        </span>
        <span class="rank-proximo">
          Próxima meta: <strong><%= usuario && usuario.pontos || 0 %> / 100 pts</strong>
        </span>
      </section>
      <section class="barra-rank" role="progressbar"
        aria-valuenow="<%= usuario && usuario.pontos || 0 %>"
        aria-valuemin="0" aria-valuemax="100">
        <section class="barra-rank-fill"
          style="width:<%= Math.min((usuario && usuario.pontos || 0), 100) %>%"></section>
      </section>
      <span class="rank-detalhe">
        <%= usuario && usuario.pontos || 0 %> pts acumulados
      </span>
    </section>

    <!-- Stats -->
    <section class="containers-gerais" aria-labelledby="sec-stats">
      <h2 class="containers-gerais-titulo" id="sec-stats">Estatísticas</h2>
      <section class="stats">
        <article class="stat">
          <h3>Pontos XP</h3>
          <p> <%= usuario && usuario.pontos || 0 %></p>
        </article>
        <article class="stat">
          <h3>Tipo de Conta</h3>
          <p style="font-size:1rem;text-transform:capitalize">
            <%= usuario && usuario.tipo ? usuario.tipo : 'cliente' %>
          </p>
        </article>
        <article class="stat">
          <h3>Membro desde</h3>
          <p style="font-size:1rem">
            <% if (usuario && usuario.criado_em) { %>
              <%= new Date(usuario.criado_em).toLocaleDateString('pt-BR', {month:'short', year:'numeric'}) %>
            <% } else { %>2025<% } %>
          </p>
        </article>
      </section>
    </section>

    <!-- Ações rápidas -->
    <section class="containers-gerais" aria-labelledby="sec-acoes">
      <h2 class="containers-gerais-titulo" id="sec-acoes">Acesso Rápido</h2>
      <nav class="item-container" aria-label="Ações do perfil">
        <a href="/tasks"><i class="bi bi-check2-circle"></i> Convidar para tarefa em grupo</a>

        <a href="#" style="color:#dc2626">
          <i class="bi bi-slash-circle" style="color:#dc2626"></i>Bloquear usuario
        </a>
        <a href="#" style="color:#dc2626">
          <i class="bi bi-flag" style="color:#dc2626"></i>Denunciar usuario
        </a>
      </nav>
    </section>
  </main>

  <%- include('../partials/footer.ejs') %>
</body>
</html>
