<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Criar conta de Profissional | Healthy Safely</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/cadastro.css" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  </head>

  <body>
    <%- include('../partials/header.ejs') %>

    <main class="main">
      <section class="card" aria-labelledby="titulo-cadastro">
        <section class="form-area">
          <form action="/cadastroProfissional" method="POST" novalidate>
            <h1 id="titulo-cadastro" class="form-title">
              Cadastro de Profissional
            </h1>

            <a
              class="btn-google"
              href="/auth/google"
              role="button"
              aria-label="Cadastrar com Google"
            >
              <i class="bi bi-google"></i>
              <p>Continuar com Google</p>
            </a>

            <section class="or" aria-hidden="true">ou</section>

            <section class="form-group">
              <label for="email" class="inputs">E-mail</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="Digite seu endereço de e-mail"
                value="<%= valores ? valores.email || '' : '' %>"
                class="<%= erroValidacao && erroValidacao.email ? 'erro-input' : '' %>"
                required
              />
              <span class="msg-erro"
                ><%= msgErro && msgErro.email ? msgErro.email : '' %></span
              >
              <p class="small">
                Digite um e-mail válido. Ele será usado para login e recuperação
                de conta.
              </p>
            </section>

            <section class="form-duplo">
              <section class="form-group">
                <label for="cref" class="inputs">CREF</label>
                <input
                  id="cref"
                  name="cref"
                  type="text"
                  placeholder="Digite seu CREF"
                  value="<%= valores ? valores.cref || '' : '' %>"
                  class="<%= erroValidacao && erroValidacao.cref ? 'erro-input' : '' %>"
                  required
                />
                <span class="msg-erro"
                  ><%= msgErro && msgErro.cref ? msgErro.cref : '' %></span
                >
                <p class="small">Informe seu registro profissional (CREF).</p>
              </section>

              <section class="form-group">
                <label for="areaAtuacao" class="inputs">Área de atuação</label>
                <select
                  id="areaAtuacao"
                  name="areaAtuacao"
                  class="<%= erroValidacao && erroValidacao.areaAtuacao ? 'erro-input' : '' %>"
                  required
                >
                  <option value="">Selecione a área</option>
                  <option value="musculacao">Musculação</option>
                  <option value="funcional">Funcional</option>
                  <option value="reabilitacao">Reabilitação</option>
                  <option value="nutricao">Nutrição</option>
                  <option value="fisioterapia">Fisioterapia</option>
                  <option value="outros">Outros</option>
                </select>
                <span class="msg-erro"
                  ><%= msgErro && msgErro.areaAtuacao ? msgErro.areaAtuacao : ''
                  %></span
                >
              </section>
            </section>

            <section class="form-group">
              <label for="tempoExperiencia" class="inputs"
                >Tempo de experiência (anos)</label
              >
              <input
                id="tempoExperiencia"
                name="tempoExperiencia"
                type="number"
                placeholder="Ex: 5"
                min="0"
                value="<%= valores ? valores.tempoExperiencia || '' : '' %>"
                class="<%= erroValidacao && erroValidacao.tempoExperiencia ? 'erro-input' : '' %>"
                required
              />
              <span class="msg-erro"
                ><%= msgErro && msgErro.tempoExperiencia ?
                msgErro.tempoExperiencia : '' %></span
              >
            </section>

            <section class="form-group">
              <label for="especialidades" class="inputs">Especialidades</label>
              <input
                id="especialidades"
                name="especialidades"
                type="text"
                placeholder="Ex: Treinamento de força, Lesões esportivas"
                value="<%= valores ? valores.especialidades || '' : '' %>"
                class="<%= erroValidacao && erroValidacao.especialidades ? 'erro-input' : '' %>"
                required
              />
              <span class="msg-erro"
                ><%= msgErro && msgErro.especialidades ? msgErro.especialidades
                : '' %></span
              >
            </section>

            <section class="form-duplo">
              <section class="form-group">
                <label for="nome" class="inputs">Nome Completo</label>
                <input
                  id="nome"
                  name="nome"
                  type="text"
                  placeholder="Digite seu nome completo"
                  value="<%= valores ? valores.nome || '' : '' %>"
                  class="<%= erroValidacao && erroValidacao.nome ? 'erro-input' : '' %>"
                  required
                />
                <span class="msg-erro"
                  ><%= msgErro && msgErro.nome ? msgErro.nome : '' %></span
                >

                <p class="small">
                  Nome deve conter entre 3 e 50 caracteres.(somente letras).
                </p>
              </section>

              <section class="form-group">
                <label for="nomeusuario" class="inputs">Nome de Usuário</label>
                <input
                  id="nomeusuario"
                  name="nomeusuario"
                  type="text"
                  placeholder="Escolha um nome de usuário"
                  value="<%= valores ? valores.nomeusuario || '' : '' %>"
                  class="<%= erroValidacao && erroValidacao.nomeusuario ? 'erro-input' : '' %>"
                  required
                />
                <span class="msg-erro"
                  ><%= msgErro && msgErro.nomeusuario ? msgErro.nomeusuario : ''
                  %></span
                >
                <p class="small">
                  Nome de usuário deve conter apenas letras, números, hífen e
                  underscore.
                </p>
              </section>
            </section>

            <section class="form-duplo">
              <section class="form-group">
                <label for="senha" class="inputs">Senha</label>
                <article class="campo-senha">
                  <input
                    id="senha"
                    name="senha"
                    type="password"
                    placeholder="Crie uma senha"
                    class="<%= erroValidacao && erroValidacao.senha ? 'erro-input' : '' %>"
                    required
                  />
                  <button
                    type="button"
                    class="btn-olho"
                    onclick="toggleSenha('senha')"
                    aria-label="Mostrar senha"
                  >
                    <i class="bi bi-eye-slash-fill"></i>
                  </button>
                </article>
                <span class="msg-erro"
                  ><%= msgErro && msgErro.senha ? msgErro.senha : '' %></span
                >
                <p class="small">
                  Senha deve conter pelo menos 8 caracteres incluindo numeros,
                  caracteres especiais,letra maiuscula e minuscula.
                </p>
              </section>

              <section class="form-group">
                <label for="confirmarSenha" class="inputs"
                  >Confirmar Senha</label
                >
                <article class="campo-senha">
                  <input
                    id="confirmarSenha"
                    name="confirmarSenha"
                    type="password"
                    placeholder="Confirme sua senha"
                    class="<%= erroValidacao && erroValidacao.confirmarSenha ? 'erro-input' : '' %>"
                    required
                  />
                  <button
                    type="button"
                    class="btn-olho"
                    onclick="toggleSenha('confirmarSenha')"
                    aria-label="Mostrar senha"
                  >
                    <i class="bi bi-eye-slash-fill"></i>
                  </button>
                </article>
                <span class="msg-erro"
                  ><%= msgErro && msgErro.confirmarSenha ?
                  msgErro.confirmarSenha : '' %></span
                >
                <p class="small">Digite novamente sua senha para confirmar.</p>
              </section>
            </section>

            <section class="actions">
              <button class="btn-primary" type="submit">Cadastrar</button>
            </section>

            <p class="small">
              Quer se tornar um cliente?
              <a href="/cadastroCliente" class="link-cadastro"
                >Cadastre-se já!</a
              >
            </p>

            <p class="small">
              Já tem uma conta?
              <a href="/login" class="link-cadastro">Faça login.</a>
            </p>
          </form>
        </section>
      </section>
    </main>

    <%- include('../partials/footer.ejs') %>
    <!---->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/validacao-front-end.js"></script>
    <script src="/js/ver-senha.js"></script>
  </body>
</html>
