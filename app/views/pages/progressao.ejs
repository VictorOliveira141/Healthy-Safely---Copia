<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Healthy Safely</title>
    <link rel="icon" href="../imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="../css/progressao.css" />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <!---->
    <%- include('../partials/menu-inferior.ejs') %>

    <!--PERFIL-->
    <header class="perfil">
      <figure class="foto-perfil">
        <img src="../imagem/user.png" alt="Foto de perfil do usuário" />
      </figure>

      <div class="info-perfil">
        <h1>Victor Hugo</h1>
        <h2>@Victor43153</h2>
        <p class="seguidores">
          <span>0 seguidores</span> • <span>0 seguindo</span>
        </p>
      </div>

      <article class="streak">
        <h2>Streak</h2>
        <p>0 dias 🔥</p>
      </article>
    </header>

    <main class="perfil-corpo">
      <!--RANK-->
      <section class="rank-container">
        <h2>🏆 Rank Atual</h2>

        <div class="rank-info">
          <span class="rank-atual">🥈 Prata I</span>
          <span class="rank-proximo">Próximo: 🥇 Ouro I</span>
        </div>

        <div class="barra-rank">
          <div class="barra-preenchimento" id="barraRank"></div>
        </div>

        <p class="rank-detalhe" id="rankDetalhe"></p>
        <p class="rank-faltando" id="rankFaltando"></p>
      </section>

      <!-- Estatísticas -->
      <section class="stats">
        <article class="stat">
          <h3>Pontuação Total</h3>
          <p>25⭐</p>
        </article>
        <article class="stat">
          <h3>Tarefas Totais Concluídas</h3>
          <p>2📋</p>
        </article>
        <article class="stat">
          <h3>Rank Atual</h3>
          <article class="medal">🥈 Prata I</article>
        </article>
      </section>

      <!-- Medalhas -->
      <section class="medals">
        <h2>Medalhas Conquistadas</h2>
        <section class="medal-list">
          <article class="medal">🥉 Corredor I</article>

          <article class="medal">🥈 Completista II</article>

          <article class="medal">🥇 Alimentação Saúdavel V</article>
        </section>
      </section>
    </main>

    <script src="../js/grafico.js"></script>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>

<!--SCRIPT DA BARRA DE PROGRESSAO-->
<script>
  // CONFIGURAÇÃO (você pode mudar esses valores)
  const pontuacaoAtual = 325;
  const pontosParaProximoRank = 500;

  const barra = document.getElementById("barraRank");
  const detalhe = document.getElementById("rankDetalhe");
  const faltando = document.getElementById("rankFaltando");

  // Calcula progresso
  let progresso = (pontuacaoAtual / pontosParaProximoRank) * 100;
  if (progresso > 100) progresso = 100;

  // Atualiza barra
  barra.style.width = progresso + "%";

  // Atualiza textos
  detalhe.textContent = `${pontuacaoAtual}⭐ / ${pontosParaProximoRank}⭐`;

  const pontosRestantes = Math.max(pontosParaProximoRank - pontuacaoAtual, 0);

  faltando.innerHTML = `Faltam <strong>${pontosRestantes}⭐</strong> para subir de rank`;
</script>
