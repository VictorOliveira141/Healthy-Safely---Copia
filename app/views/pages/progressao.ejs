<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Healthy Safely</title>
    <link rel="icon" href="../imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="../css/progressao.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <!---->
    <%- include('../partials/menu-inferior.ejs') %>

    <!--PERFIL-->
    <header class="perfil">
      <figure class="foto-perfil">
        <img src="../imagem/user.png" alt="Foto de perfil do usuário" />
      </figure>

      <section class="info-perfil">
        <h1><%= usuario.nome.split(' ').slice(0,2).join(' ') %></h1>
        <h2>@<%= usuario.nomeusuario %></h2>
        <p class="seguidores">
          <span><%= usuario.seguidores || 0 %> seguidores</span> •
          <span><%= usuario.seguindo || 0 %> seguindo</span>
        </p>
      </section>

      <article class="streak">
        <h2>Streak</h2>
        <p><%= usuario.streak || 0 %> dias <i class="fa-solid fa-fire"></i></p>
      </article>
    </header>

    <main class="perfil-corpo">
      <!--RANK-->
      <section class="rank-container">
        <h2><i class="fa-solid fa-ranking-star"></i> Rank Atual</h2>
        <section class="rank-info">
          <span class="rank-atual"
            ><i class="fa-solid fa-trophy" style="color: #a67b5b"></i> Bronze
            I</span
          >
          <span class="rank-proximo"
            >Próximo:
            <i class="fa-solid fa-trophy" style="color: #a67b5b"></i> Bronze
            II</span
          >
        </section>

        <section class="barra-rank">
          <section class="barra-preenchimento"></section>
        </section>

        <p><%= usuario.xp || 0 %>/500</p>
        <p class="rank-detalhe">
          Faltam <%= 500 - (usuario.ranked || 0) %> XP para subir de rank
        </p>
      </section>

      <!-- Estatísticas -->
      <section class="stats">
        <article class="stat">
          <h3>XP TOTAL</h3>
          <p><%= usuario.pontuacao || 0 %><i class="fa-solid fa-star"></i></p>
        </article>
        <article class="stat">
          <h3>TAREFAS TOTAIS CONCLUÍDAS</h3>
          <p>
            <%= usuario.tarefasConcluidas || 0 %><i
              class="fa-solid fa-book"
            ></i>
          </p>
        </article>
        <article class="stat">
          <h3>MEDALHAS TOTAIS</h3>
          <p><%= usuario.medalhas || 0 %><i class="fa-solid fa-medal"></i></p>
        </article>
      </section>

      <!-- Medalhas -->
      <section class="medals">
        <h2><i class="fa-solid fa-medal"></i> Medalhas Conquistadas</h2>
        <section class="medal-list">
          <article class="medal-item">
            <figure class="medal">
              <img
                src="../imagem/oie_transparent.png"
                alt="Medalha de Bronze"
                width="80px"
                height="80px"
              />
            </figure>
            <p>Corredor I</p>
          </article>
          <article class="medal-item">
            <figure class="medal">
              <img
                src="../imagem/oie_transparent.png"
                alt="Medalha de Bronze"
                width="80px"
                height="80px"
              />
            </figure>
            <p>Corredor II</p>
          </article>
        </section>
      </section>
    </main>

    <footer class="perfil-footer">
      <section class="central-conta">
        <h2><i class="fa-solid fa-user"></i> Central da Conta</h2>
        <article class="perfil-botoes">
          <p><i class="fa-solid fa-gear"></i> Configurações</p>
          <p><i class="fa-solid fa-shield-halved"></i> Privacidade</p>
          <p><i class="fa-solid fa-bell"></i> Notificações</p>
          <p><i class="fa-solid fa-heart"></i> Ajuda</p>
          <a href="/logout"
            ><p>
              <i class="fa-solid fa-right-from-bracket"></i> Sair da Conta
            </p></a
          >
        </article>
      </section>
    </footer>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>
