<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Saiba como o Healthy Safely protege seus dados. Veja nossas políticas de privacidade, uso de informações, segurança e controle da sua conta."
    />
    <title>Privacidade | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/privacidade.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>

    <main class="priv-main" aria-labelledby="titulo-priv">
      <%- include('../partials/botao-voltar.ejs') %>
      <h1 class="priv-titulo" id="titulo-priv">
        <i class="bi bi-shield-fill-check" aria-hidden="true"></i>
        Privacidade
      </h1>
      <p class="priv-subtitulo">
        Gerencie como seus dados são usados na plataforma
      </p>

      <aside class="priv-info-box" role="note">
        <i class="bi bi-info-circle-fill" aria-hidden="true"></i>
        <p>
          Levamos sua privacidade a sério. Seus dados são armazenados com
          segurança e nunca compartilhados sem o seu consentimento. Leia nossa
          <a href="#">Política de Privacidade</a> completa.
        </p>
      </aside>

      <!-- VISIBILIDADE DO PERFIL -->
      <section class="priv-grupo" aria-labelledby="grupo-perfil">
        <h2 class="priv-grupo-titulo" id="grupo-perfil">
          Visibilidade do Perfil
        </h2>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-eye-fill"></i>
            </figure>
            <section>
              <span class="priv-nome">Perfil público</span>
              <span class="priv-desc"
                >Outros usuários podem visualizar seu perfil e progresso</span
              >
            </section>
          </section>
          <label class="toggle" aria-label="Tornar perfil público">
            <input type="checkbox" id="perfilPublico" checked />
            <span class="slider-toggle"></span>
          </label>
        </article>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-graph-up-arrow"></i>
            </figure>
            <section>
              <span class="priv-nome">Exibir progresso</span>
              <span class="priv-desc"
                >Mostrar suas estatísticas e streak no ranking</span
              >
            </section>
          </section>
          <label class="toggle" aria-label="Exibir progresso publicamente">
            <input type="checkbox" id="exibirProgresso" checked />
            <span class="slider-toggle"></span>
          </label>
        </article>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-trophy-fill"></i>
            </figure>
            <section>
              <span class="priv-nome">Exibir medalhas</span>
              <span class="priv-desc"
                >Mostrar suas conquistas para outros usuários</span
              >
            </section>
          </section>
          <label class="toggle" aria-label="Exibir medalhas publicamente">
            <input type="checkbox" id="exibirMedalhas" checked />
            <span class="slider-toggle"></span>
          </label>
        </article>
      </section>

      <!-- DADOS E ANALYTICS -->
      <section class="priv-grupo" aria-labelledby="grupo-dados">
        <h2 class="priv-grupo-titulo" id="grupo-dados">Dados e Uso</h2>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-bar-chart-fill"></i>
            </figure>
            <section>
              <span class="priv-nome">Analytics de uso</span>
              <span class="priv-desc"
                >Permitir coleta de dados anônimos para melhorar a
                plataforma</span
              >
            </section>
          </section>
          <label class="toggle" aria-label="Permitir analytics de uso">
            <input type="checkbox" id="analytics" checked />
            <span class="slider-toggle"></span>
          </label>
        </article>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-share-fill"></i>
            </figure>
            <section>
              <span class="priv-nome">Compartilhar com profissional</span>
              <span class="priv-desc"
                >Liberar acesso ao seu progresso para seu profissional de
                saúde</span
              >
            </section>
          </section>
          <label
            class="toggle"
            aria-label="Compartilhar dados com profissional"
          >
            <input type="checkbox" id="compartilharPro" checked />
            <span class="slider-toggle"></span>
          </label>
        </article>
      </section>

      <!-- SEUS DADOS -->
      <section class="priv-grupo" aria-labelledby="grupo-seus-dados">
        <h2 class="priv-grupo-titulo" id="grupo-seus-dados">Seus Dados</h2>

        <article class="priv-item">
          <section class="priv-item-esq">
            <figure class="priv-icone" aria-hidden="true">
              <i class="bi bi-download"></i>
            </figure>
            <section>
              <span class="priv-nome">Baixar meus dados</span>
              <span class="priv-desc"
                >Receba um arquivo com todos os seus dados cadastrados</span
              >
            </section>
          </section>
          <i
            class="bi bi-chevron-right"
            style="color: var(--muted)"
            aria-hidden="true"
          ></i>
        </article>
      </section>

      <button class="btn-salvar-priv" onclick="salvarPriv()" type="button">
        Salvar preferências
      </button>
      <p class="msg-salvo" id="msgSalvo" role="status">
        ✅ Preferências salvas com sucesso!
      </p>
    </main>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>
