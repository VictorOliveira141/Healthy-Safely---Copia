<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/cadastro.css" />
    <link rel="stylesheet" href="/css/global.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <style>
      .cadastro-escolha {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem 5rem;
      }

      .cadastro-card {
        background: var(--primary-color);
        border-radius: var(--border-radius);
        border: 1px solid var(--border);
        padding: 2.5rem 2rem;
        max-width: 480px;
        width: 100%;
        text-align: center;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
      }

      .cadastro-card h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--fundoclaro);
        margin-bottom: 0.4rem;
      }

      .cadastro-card p {
        color: var(--muted);
        font-size: var(--font-text);
        margin-bottom: 2rem;
      }

      .opcoes-tipo {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .opcao-tipo {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: var(--border-radius);
        text-decoration: none;
        color: var(--fundoclaro);
        background: var(--primary-color);
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .opcao-tipo:hover {
        border-color: var(--accent-color);
        box-shadow: 0 4px 16px rgba(26, 138, 117, 0.12);
        transform: var(--animacao);
      }

      .opcao-icone {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #e6f4f1;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.4rem;
        color: var(--secondary-color);
      }

      .opcao-texto {
        text-align: left;
      }

      .opcao-texto strong {
        display: block;
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 2px;
      }

      .opcao-texto span {
        font-size: var(--font-text);
        color: var(--muted);
      }

      .opcao-seta {
        margin-left: auto;
        color: var(--muted);
        font-size: 1.1rem;
      }

      .divisor {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.5rem 0;
        color: var(--muted);
        font-size: var(--font-text);
      }

      .divisor::before,
      .divisor::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      .link-login {
        font-size: var(--font-text);
        color: var(--muted);
      }

      .link-login a {
        color: var(--accent-color);
        font-weight: 600;
        text-decoration: none;
      }

      .link-login a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <%- include('../partials/tema.ejs') %>

    <main class="cadastro-escolha">
      <article class="cadastro-card" aria-labelledby="titulo-cadastro">
        <h1 id="titulo-cadastro">Criar conta</h1>
        <p>Escolha como você deseja se cadastrar na plataforma</p>

        <nav class="opcoes-tipo" aria-label="Tipos de cadastro disponíveis">
          <a href="/cadastroCliente" class="opcao-tipo" aria-label="Cadastrar como Usuário comum">
            <figure class="opcao-icone" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </figure>
            <section class="opcao-texto">
              <strong>Usuário</strong>
              <span>Acompanhe sua saúde, tarefas e progresso diário</span>
            </section>
            <i class="bi bi-chevron-right opcao-seta" aria-hidden="true"></i>
          </a>

          <a href="/cadastroProfissional" class="opcao-tipo" aria-label="Cadastrar como Profissional de saúde">
            <figure class="opcao-icone" aria-hidden="true">
              <i class="bi bi-briefcase-fill"></i>
            </figure>
            <section class="opcao-texto">
              <strong>Profissional</strong>
              <span>Gerencie pacientes e acompanhe seu desempenho</span>
            </section>
            <i class="bi bi-chevron-right opcao-seta" aria-hidden="true"></i>
          </a>
        </nav>

        <p class="divisor">já tem uma conta?</p>

        <p class="link-login">
          Faça <a href="/login">login aqui</a>
        </p>
      </article>
    </main>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>
