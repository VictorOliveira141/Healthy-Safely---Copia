<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Login | Healthy Safely - Hábitos Saudáveis</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/cadastro.css" />
    <link rel="stylesheet" href="/css/global.css" />
  </head>

  <body>
    <%- include('../partials/header.ejs') %>
    <main>
      <article class="card" aria-labelledby="titulo-login">
        <section class="form-area">
          <form
            action="/login"
            method="POST"
            novalidate
            aria-labelledby="titulo-login"
          >
            <h1 id="titulo-login" class="form-title">Entrar na sua conta</h1>

           <a
              class="btn-google"
              href="/auth/google"
              role="button"
              aria-label="Cadastrar com Google"
            >
              <i class="bi bi-google"></i>
              <p>Continuar com Google</p>
            </a>

            <section class="or" aria-hidden="true">ou</section>

            <section>
              <label class="inputs" for="email"
                >E-mail ou Nome de Usuário</label
              >
              <input
                id="email"
                name="email-login"
                type="text"
                placeholder="seu@exemplo.com"
                value="<%= valores ? valores.email || '' : '' %>"
                class="<%= erroValidacao && erroValidacao.email ? 'erro-input' : '' %>"
                autocomplete="email"
              />
              <span class="msg-erro"
                ><%= msgErro && msgErro.email ? msgErro.email : '' %></span
              >
            </section>

            
            <section class="espaco-campo">
              <label class="inputs" for="senha">Senha</label>
              <section class="campo-senha">
                <input
                  id="senha"
                  name="senha-login"
                  type="password"
                  placeholder="Sua senha"
                  class="<%= erroValidacao && erroValidacao.senha ? 'erro-input' : '' %>"
                  autocomplete="current-password"
                />
                <button
                  type="button"
                  class="btn-olho"
                  onclick="toggleSenha('senha')"
                  aria-label="Mostrar senha"
                >
                  <i class="bi bi-eye-slash-fill"></i>
                </button>
              </section>
              <span class="msg-erro"
                ><%= msgErro && msgErro.senha ? msgErro.senha : '' %></span
              >
            </section>

            <% if (typeof erro !== 'undefined' && erro) { %>
            <section
              style="
                color: #ff6b6b;
                font-size: 13px;
                background-color: rgba(255, 107, 107, 0.05);
                padding: 10px;
                border-radius: 6px;
                margin-bottom: 12px;
                border-left: 3px solid #ff6b6b;
                margin-top: 10px;
              "
            >
              <%= erro %>
            </section>
            <% } %>

            <section class="actions">
              <button class="btn-primary" type="submit">Entrar</button>
            </section>
            <p class="small">
              Esqueceu sua senha?
              <a class="link-cadastro" href="#"> Recupere</a>!
            </p>

            <p class="small">
              Ainda não tem uma conta? Cadastra-se como um
              <a href="/cadastroCliente" class="link-cadastro">Cliente </a> ou
              <a href="/cadastroProfissional" class="link-cadastro"
                >Profissional</a
              >!
            </p>
          </form>
        </section>
      </article>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/validacao-front-end.js"></script>
    <script src="/js/ver-senha.js"></script>
  </body>
</html>
