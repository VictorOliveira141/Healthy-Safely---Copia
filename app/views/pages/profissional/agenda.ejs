<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agenda | Área Profissional - Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
    <link rel="stylesheet" href="/css/global.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <style>
      .agenda-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 1.5rem;
      }

      @media (max-width: 860px) {
        .agenda-layout { grid-template-columns: 1fr; }
      }

      /* Mini calendário */
      .calendario-mini {
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        padding: 1.25rem;
        height: fit-content;
      }

      .cal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
      }

      .cal-header h3 {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--fundoclaro);
      }

      .cal-nav-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--primary-color);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 0.8rem;
        transition: background 0.15s;
      }

      .cal-nav-btn:hover { background: var(--surface-bg); color: var(--secondary-color); }

      .cal-dias-semana {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
        margin-bottom: 4px;
      }

      .cal-dias-semana abbr {
        text-align: center;
        font-size: 10px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        text-decoration: none;
        display: block;
        padding: 4px 0;
      }

      .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
      }

      .cal-dia {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        font-size: 0.8rem;
        cursor: pointer;
        color: var(--fundoclaro);
        transition: background 0.15s;
        border: none;
        background: none;
      }

      .cal-dia:hover { background: #e6f4f1; }
      .cal-dia.hoje { background: var(--secondary-color); color: #fff; font-weight: 700; }
      .cal-dia.selecionado { background: var(--accent-color); color: #fff; }
      .cal-dia.tem-consulta { position: relative; }
      .cal-dia.tem-consulta::after {
        content: '';
        position: absolute;
        bottom: 3px;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent-color);
      }
      .cal-dia.hoje.tem-consulta::after { background: #fff; }
      .cal-dia.vazio { cursor: default; }

      /* Consultas do dia */
      .consultas-dia {
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        padding: 1.5rem;
      }

      .consultas-dia-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .consultas-dia-header h2 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--fundoclaro);
      }

      .btn-nova-consulta {
        padding: 0.45rem 0.9rem;
        background: var(--secondary-color);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: var(--font-text);
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        transition: opacity 0.2s;
      }

      .btn-nova-consulta:hover { opacity: 0.88; }

      .consultas-lista {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .consulta-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: box-shadow 0.15s;
      }

      .consulta-item:hover {
        box-shadow: 0 4px 14px rgba(12,79,67,0.08);
      }

      .consulta-hora {
        text-align: center;
        min-width: 52px;
        flex-shrink: 0;
      }

      .consulta-hora strong {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--secondary-color);
      }

      .consulta-hora span {
        font-size: 10px;
        color: var(--muted);
      }

      .consulta-info {
        flex: 1;
      }

      .consulta-info strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--fundoclaro);
        margin-bottom: 3px;
      }

      .consulta-info p {
        font-size: var(--font-text);
        color: var(--muted);
        margin: 0;
      }

      .consulta-tipo {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
      }

      .consulta-tipo.presencial { background: rgba(26,138,117,0.15); color: var(--accent-color); }
      .consulta-tipo.online { background: #f0f4ff; color: #4f63d2; }
      .consulta-tipo.retorno { background: #fff8e1; color: #b36a00; }

      .linha-tempo {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        flex-shrink: 0;
      }

      .bolinha-tempo {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent-color);
        flex-shrink: 0;
      }

      .linha-conector {
        width: 2px;
        flex: 1;
        min-height: 30px;
        background: var(--border);
      }

      .consulta-item:last-child .linha-conector { display: none; }

      .dia-vazio {
        text-align: center;
        padding: 2.5rem 1rem;
        color: var(--muted);
      }

      .dia-vazio i {
        font-size: 2rem;
        display: block;
        margin-bottom: 0.5rem;
        opacity: 0.4;
      }
    </style>
  </head>
  <body>
    <%- include('../../partials/header.ejs') %>
    <%- include('../../partials/menu-inferior.ejs') %>

    <section class="admin-container">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="admin-main" aria-labelledby="titulo-agenda">
        <h1 id="titulo-agenda" style="font-size:1.4rem;font-weight:700;color:var(--fundoclaro);margin-bottom:1.5rem;">
          <i class="bi bi-calendar-check-fill" aria-hidden="true"></i>
          Agenda de Consultas
        </h1>

        <section class="agenda-layout">

          <!-- CALENDÁRIO MINI -->
          <aside aria-label="Calendário de navegação">
            <section class="calendario-mini">
              <header class="cal-header">
                <button class="cal-nav-btn" onclick="navegarMes(-1)" aria-label="Mês anterior" type="button">
                  <i class="bi bi-chevron-left" aria-hidden="true"></i>
                </button>
                <h3 id="cal-titulo">Março 2026</h3>
                <button class="cal-nav-btn" onclick="navegarMes(1)" aria-label="Próximo mês" type="button">
                  <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </button>
              </header>

              <section class="cal-dias-semana" aria-hidden="true">
                <abbr title="Domingo">D</abbr>
                <abbr title="Segunda">S</abbr>
                <abbr title="Terça">T</abbr>
                <abbr title="Quarta">Q</abbr>
                <abbr title="Quinta">Q</abbr>
                <abbr title="Sexta">S</abbr>
                <abbr title="Sábado">S</abbr>
              </section>

              <section class="cal-grid" id="calGrid" aria-label="Dias do mês"></section>
            </section>

            <!-- Resumo rápido -->
            <section class="calendario-mini" style="margin-top:1rem;">
              <h3 style="font-size:0.875rem;font-weight:700;color:var(--fundoclaro);margin-bottom:1rem;">
                Resumo do mês
              </h3>
              <section style="display:flex;flex-direction:column;gap:0.6rem;">
                <section style="display:flex;justify-content:space-between;font-size:var(--font-text);">
                  <span style="color:var(--muted);">Consultas agendadas</span>
                  <strong style="color:var(--secondary-color);">7</strong>
                </section>
                <section style="display:flex;justify-content:space-between;font-size:var(--font-text);">
                  <span style="color:var(--muted);">Concluídas</span>
                  <strong style="color:var(--secondary-color);">54</strong>
                </section>
                <section style="display:flex;justify-content:space-between;font-size:var(--font-text);">
                  <span style="color:var(--muted);">Canceladas</span>
                  <strong style="color:#e55353;">2</strong>
                </section>
              </section>
            </section>
          </aside>

          <!-- CONSULTAS DO DIA -->
          <section class="consultas-dia" aria-labelledby="titulo-consultas-dia">
            <header class="consultas-dia-header">
              <h2 id="titulo-consultas-dia">
                Consultas de <time id="dataExibida">31 de março de 2026</time>
              </h2>
              <button class="btn-nova-consulta" type="button" onclick="novaConsulta()">
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                Agendar
              </button>
            </header>

            <section class="consultas-lista" id="listaConsultas" aria-live="polite">

              <article class="consulta-item">
                <section class="linha-tempo" aria-hidden="true">
                  <span class="bolinha-tempo"></span>
                  <span class="linha-conector"></span>
                </section>
                <section class="consulta-hora">
                  <strong>09h00</strong>
                  <span>30 min</span>
                </section>
                <section class="consulta-info">
                  <strong>Kauã Mauricio</strong>
                  <p>Consulta de retorno — Acompanhamento físico</p>
                </section>
                <span class="consulta-tipo retorno">Retorno</span>
              </article>

              <article class="consulta-item">
                <section class="linha-tempo" aria-hidden="true">
                  <span class="bolinha-tempo"></span>
                  <span class="linha-conector"></span>
                </section>
                <section class="consulta-hora">
                  <strong>10h30</strong>
                  <span>1h</span>
                </section>
                <section class="consulta-info">
                  <strong>Ana Clara Souza</strong>
                  <p>Primeira consulta — Saúde mental e bem-estar</p>
                </section>
                <span class="consulta-tipo presencial">Presencial</span>
              </article>

              <article class="consulta-item">
                <section class="linha-tempo" aria-hidden="true">
                  <span class="bolinha-tempo"></span>
                  <span class="linha-conector"></span>
                </section>
                <section class="consulta-hora">
                  <strong>14h00</strong>
                  <span>45 min</span>
                </section>
                <section class="consulta-info">
                  <strong>Daniel Renovato</strong>
                  <p>Consulta nutricional — Revisão de plano alimentar</p>
                </section>
                <span class="consulta-tipo online">Online</span>
              </article>

            </section>
          </section>

        </section>
      </main>
    </section>

    <%- include('../../partials/footer.ejs') %>

    <script>
      const MESES = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
      const MESES_EXTENSO = MESES;
      const diasComConsulta = [5, 12, 18, 22, 31];

      let anoAtual = 2026;
      let mesAtual = 2; // 0-indexed: março = 2

      function renderCalendario() {
        const grid = document.getElementById('calGrid');
        const titulo = document.getElementById('cal-titulo');
        titulo.textContent = `${MESES[mesAtual]} ${anoAtual}`;
        grid.innerHTML = '';

        const primeiroDia = new Date(anoAtual, mesAtual, 1).getDay();
        const totalDias = new Date(anoAtual, mesAtual + 1, 0).getDate();
        const hoje = new Date();
        const ehMesAtual = hoje.getMonth() === mesAtual && hoje.getFullYear() === anoAtual;

        for (let i = 0; i < primeiroDia; i++) {
          const vazio = document.createElement('span');
          vazio.className = 'cal-dia vazio';
          grid.appendChild(vazio);
        }

        for (let d = 1; d <= totalDias; d++) {
          const btn = document.createElement('button');
          btn.className = 'cal-dia';
          btn.textContent = d;
          btn.type = 'button';
          btn.setAttribute('aria-label', `${d} de ${MESES[mesAtual]}`);
          if (ehMesAtual && d === hoje.getDate()) btn.classList.add('hoje');
          if (diasComConsulta.includes(d)) btn.classList.add('tem-consulta');
          btn.addEventListener('click', () => selecionarDia(d, btn));
          grid.appendChild(btn);
        }
      }

      function selecionarDia(dia, btn) {
        document.querySelectorAll('.cal-dia.selecionado').forEach(b => b.classList.remove('selecionado'));
        btn.classList.add('selecionado');
        const dataEl = document.getElementById('dataExibida');
        dataEl.textContent = `${dia} de ${MESES_EXTENSO[mesAtual]} de ${anoAtual}`;
        dataEl.setAttribute('datetime', `${anoAtual}-${String(mesAtual+1).padStart(2,'0')}-${String(dia).padStart(2,'0')}`);
      }

      function navegarMes(delta) {
        mesAtual += delta;
        if (mesAtual < 0) { mesAtual = 11; anoAtual--; }
        if (mesAtual > 11) { mesAtual = 0; anoAtual++; }
        renderCalendario();
      }

      function novaConsulta() {
        alert('Agendamento de consulta será implementado com banco de dados.');
      }

      renderCalendario();
    </script>
  </body>
</html>
