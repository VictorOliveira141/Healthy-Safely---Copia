<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <script src="/js/darkmode.js"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tarefas do Paciente | Healthy Safely</title>
  <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  <style>
    .pac-hero{background:linear-gradient(135deg,#012e22,#0f5e50);padding:2rem;
      border-radius:14px;margin-bottom:2rem;color:#fff;}
    .pac-hero h1{font-size:1.4rem;font-weight:900;margin-bottom:.25rem;}
    .pac-hero p{opacity:.7;font-size:.9rem;}
    .pac-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem;}
    .pac-stat{background:var(--surface-card, var(--primary-color));border:1px solid var(--border);border-radius:12px;
      padding:1rem;text-align:center;box-shadow:0 2px 8px rgba(12,79,67,.07);}
    .pac-stat strong{display:block;font-size:1.6rem;font-weight:900;color:var(--fundoclaro);}
    .pac-stat span{font-size:.75rem;color:var(--muted);font-weight:600;}
    .pac-pct-track{width:100%;height:6px;background:var(--border);border-radius:6px;overflow:hidden;margin-top:.35rem;}
    .pac-pct-fill{height:100%;background:linear-gradient(90deg,#0c4f43,#34d399);border-radius:6px;}
    .add-form{background:var(--surface-card, var(--primary-color));border:1px solid var(--border);border-radius:14px;
      padding:1.5rem;margin-bottom:2rem;box-shadow:0 2px 8px rgba(12,79,67,.07);}
    .add-form h2{font-size:1rem;font-weight:800;margin-bottom:1rem;color:var(--fundoclaro);}
    .form-row{display:flex;gap:.75rem;flex-wrap:wrap;}
    .form-row input,.form-row select{flex:1;min-width:140px;padding:.65rem .9rem;
      border:1.5px solid var(--border);border-radius:10px;font-family:inherit;font-size:.88rem;
      color:var(--fundoclaro);background:var(--surface-bg, var(--primary-color));}
    .form-row input:focus,.form-row select:focus{outline:none;border-color:var(--accent-color);}
    .btn-add{padding:.65rem 1.25rem;background:#0c4f43;color:#fff;border:none;
      border-radius:10px;font-family:inherit;font-size:.88rem;font-weight:700;cursor:pointer;
      white-space:nowrap;transition:background .2s;display:inline-flex;align-items:center;gap:.35rem;}
    .btn-add:hover{background:#0f5e50;}
    .tarefa-lista{display:flex;flex-direction:column;gap:.65rem;}
    .tarefa-item{background:var(--surface-card, var(--primary-color));border:1px solid var(--border);border-radius:12px;
      padding:.9rem 1.1rem;display:flex;align-items:center;gap:.75rem;
      box-shadow:0 2px 8px rgba(12,79,67,.07);}
    .tarefa-item.concluida{border-left:3px solid #34d399;background:linear-gradient(90deg,#f0fdf4,#fff);}
    .t-icon{width:38px;height:38px;border-radius:9px;background:#d1fae5;
      display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
    .t-info{flex:1;}
    .t-nome{font-size:.9rem;font-weight:700;color:var(--fundoclaro);}
    .t-pts{font-size:.72rem;color:#1a8a75;font-weight:700;}
    .t-badge{font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:20px;}
    .t-badge.feita{background:#d1fae5;color:var(--fundoclaro);}
    .t-badge.pendente{background:#fef3c7;color:#92400e;}
    .t-badge.prof{background:#dbeafe;color:#1e40af;}
    .empty{text-align:center;padding:2rem;color:var(--muted);}
    .empty i{font-size:2rem;display:block;margin-bottom:.5rem;opacity:.35;}
    @media(max-width:600px){.pac-stats{grid-template-columns:1fr;}.form-row{flex-direction:column;}}
  </style>
</head>
<body>
<%- include('../../partials/header.ejs') %>
<%- include('../../partials/menu-inferior.ejs') %>

<section class="admin-container">
  <%- include('../../partials/adm/sidebar-profissional.ejs') %>
  <main class="admin-main">
    <% const concl = tarefas.filter(t=>t.concluida).length; %>
    <% const pct = tarefas.length ? Math.round((concl/tarefas.length)*100) : 0; %>

    <!-- Hero -->
    <section class="pac-hero">
      <h1><i class="bi bi-person-fill"></i> <%= paciente?.nome || 'Paciente' %></h1>
      <p><%= paciente?.email %> · Nível: <%= paciente?.nivel %> · ⭐ <%= paciente?.pontos %> pts</p>
    </section>

    <!-- Stats -->
    <section class="pac-stats">
      <article class="pac-stat">
        <strong><%= tarefas.length %></strong>
        <span>Total de tarefas</span>
      </article>
      <article class="pac-stat">
        <strong style="color:#34d399"><%= concl %></strong>
        <span>Concluídas</span>
        <section class="pac-pct-track"><section class="pac-pct-fill" style="width:<%= pct %>%"></section></section>
      </article>
      <article class="pac-stat">
        <strong style="color:#f59e0b"><%= tarefas.length - concl %></strong>
        <span>Pendentes</span>
      </article>
    </section>

    <!-- Criar tarefa para o paciente -->
    <section class="add-form">
      <h2><i class="bi bi-plus-circle-fill" style="color:#1a8a75"></i> Criar tarefa para este paciente</h2>
      <form action="/profissional/paciente/tarefa/criar" method="POST">
        <input type="hidden" name="clienteId" value="<%= paciente?.id %>" />
        <section class="form-row">
          <input type="text" name="titulo" placeholder="Título da tarefa" required maxlength="200" />
          <select name="categoria">
            <option value="geral">Geral</option>
            <option value="saude">Saúde</option>
            <option value="sono">Sono</option>
            <option value="alimentacao">Alimentação</option>
            <option value="exercicio">Exercício</option>
          </select>
          <input type="number" name="pontos" value="10" min="1" max="100" style="max-width:100px" />
          <button type="submit" class="btn-add">
            <i class="bi bi-send-fill"></i> Enviar tarefa
          </button>
        </section>
      </form>
    </section>

    <!-- Lista de tarefas -->
    <section>
      <h2 style="font-size:1rem;font-weight:800;color:#0d2b22;margin-bottom:1rem">
        Tarefas do Paciente
      </h2>
      <% if(!tarefas.length){ %>
        <section class="empty">
          <i class="bi bi-inbox"></i>
          <p>Nenhuma tarefa atribuída ainda.</p>
        </section>
      <% } else { %>
      <section class="tarefa-lista">
        <% tarefas.forEach(t => { %>
        <article class="tarefa-item <%= t.concluida ? 'concluida' : '' %>">
          <figure class="t-icon">
            <% const ic={saude:'💊',sono:'🌙',alimentacao:'🥗',exercicio:'💪',geral:'✅'}; %>
            <%= ic[t.categoria]||'✅' %>
          </figure>
          <section class="t-info">
            <p class="t-nome" style="<%= t.concluida?'text-decoration:line-through;opacity:.55':'' %>">
              <%= t.titulo %>
            </p>
            <span class="t-pts">+<%= t.pontos %> pts · <%= t.categoria %></span>
          </section>
          <span class="t-badge <%= t.concluida?'feita':'pendente' %>">
            <%= t.concluida ? '✓ Feita' : '⏳ Pendente' %>
          </span>
          <% if(t.criado_por){ %><span class="t-badge prof">👨‍⚕️ Profissional</span><% } %>
        </article>
        <% }) %>
      </section>
      <% } %>
    </section>

    <section style="margin-top:2rem">
      <a href="/profissional/pacientes" style="font-size:.85rem;color:#1a8a75;font-weight:600;text-decoration:none">
        ← Voltar à lista de pacientes
      </a>
    </section>
  </main>
</section>

<%- include('../../partials/footer.ejs') %>
</body>
</html>
