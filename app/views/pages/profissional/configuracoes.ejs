<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Gerencie as configurações do painel profissional no Healthy Safely. Ajuste aparência, notificações, conta e atalhos do seu fluxo de trabalho."
    />
    <title>Configurações Profissionais | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/configuracoes.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <%- include("../../partials/header.ejs") %>

    <div class="pro-config-shell">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="pro-config-main">
        <section class="config-main" aria-labelledby="titulo-config">
          <%- include('../../partials/botao-voltar.ejs') %>

          <header class="pro-config-hero">
            <h2>
              <i class="bi bi-gear-fill"></i> Configurações do painel
              profissional
            </h2>
            <p>
              Ajuste preferências do painel, receba alertas relevantes e
              mantenha seus atalhos de trabalho organizados.
            </p>
          </header>

          <section class="config-grid" aria-label="Resumo profissional">
            <article class="config-resumo">
              <figure class="config-icone" aria-hidden="true">
                <i class="bi bi-person-badge-fill"></i>
              </figure>
              <section>
                <strong
                  ><%= colaborador?.nome || usuario?.nome || 'Profissional'
                  %></strong
                >
                <span>Painel vinculado à sua conta profissional</span>
              </section>
            </article>

            <article class="config-resumo">
              <figure class="config-icone" aria-hidden="true">
                <i class="bi bi-bar-chart-line-fill"></i>
              </figure>
              <section>
                <strong>Atalhos de gestão</strong>
                <span>Planos, pacientes, agenda e perfil em um só lugar</span>
              </section>
            </article>
          </section>

          <section class="config-grupo" aria-labelledby="grupo-conta">
            <h2 class="config-grupo-titulo" id="grupo-conta">
              Conta profissional
            </h2>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-person-badge-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Editar perfil profissional</span>
                  <span class="config-desc"
                    >Informações, foto e dados da sua conta</span
                  >
                </section>
              </section>
              <a
                href="/profissional/perfil-profissional"
                aria-label="Ir para o perfil profissional"
              >
                <i
                  class="bi bi-chevron-right config-seta"
                  aria-hidden="true"
                ></i>
              </a>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-envelope-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">E-mail cadastrado</span>
                  <span class="config-desc"
                    ><%= colaborador?.email || usuario?.email || 'sem@email.com'
                    %></span
                  >
                </section>
              </section>
              <i class="bi bi-chevron-right config-seta" aria-hidden="true"></i>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-shield-lock-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Alterar senha</span>
                  <span class="config-desc"
                    >Redefina o acesso da conta profissional</span
                  >
                </section>
              </section>
              <i class="bi bi-chevron-right config-seta" aria-hidden="true"></i>
            </article>
          </section>

          <section class="config-grupo" aria-labelledby="grupo-operacao">
            <h2 class="config-grupo-titulo" id="grupo-operacao">
              Operação do painel
            </h2>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-bag-heart-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Meus planos</span>
                  <span class="config-desc"
                    >Gerencie ofertas, preços e tarefas semanais</span
                  >
                </section>
              </section>
              <a href="/profissional/planos" aria-label="Ir para meus planos">
                <i
                  class="bi bi-chevron-right config-seta"
                  aria-hidden="true"
                ></i>
              </a>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-people-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Pacientes</span>
                  <span class="config-desc"
                    >Acesse sua lista de pacientes e progresso</span
                  >
                </section>
              </section>
              <a href="/profissional/pacientes" aria-label="Ir para pacientes">
                <i
                  class="bi bi-chevron-right config-seta"
                  aria-hidden="true"
                ></i>
              </a>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-calendar-check-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Agenda</span>
                  <span class="config-desc"
                    >Consultas, encaixes e compromissos do dia</span
                  >
                </section>
              </section>
              <a href="/profissional/agenda" aria-label="Ir para agenda">
                <i
                  class="bi bi-chevron-right config-seta"
                  aria-hidden="true"
                ></i>
              </a>
            </article>
          </section>

          <section class="config-grupo" aria-labelledby="grupo-aparencia">
            <h2 class="config-grupo-titulo" id="grupo-aparencia">Aparência</h2>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-moon-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Modo de aparência</span>
                  <span class="config-desc"
                    >Escolha automático, claro ou escuro</span
                  >
                </section>
              </section>
              <select
                class="config-select"
                id="selectTheme"
                aria-label="Selecionar modo de aparência"
              >
                <option value="auto">Automático</option>
                <option value="light">Claro</option>
                <option value="dark">Escuro</option>
              </select>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-translate"></i>
                </figure>
                <section>
                  <span class="config-nome">Idioma</span>
                  <span class="config-desc">Idioma da interface</span>
                </section>
              </section>
              <select class="config-select" aria-label="Selecionar idioma">
                <option selected>Português (BR)</option>
                <option>English</option>
                <option>Español</option>
              </select>
            </article>
          </section>

          <section class="config-grupo" aria-labelledby="grupo-notificacoes">
            <h2 class="config-grupo-titulo" id="grupo-notificacoes">
              Notificações
            </h2>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-bell-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Novos pacientes</span>
                  <span class="config-desc"
                    >Receba avisos sobre novos vínculos</span
                  >
                </section>
              </section>
              <label
                class="toggle"
                aria-label="Ativar notificações de novos pacientes"
              >
                <input type="checkbox" checked />
                <span class="slider-toggle"></span>
              </label>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-bag-heart-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Compras de planos</span>
                  <span class="config-desc"
                    >Avisos quando um plano for vendido</span
                  >
                </section>
              </section>
              <label
                class="toggle"
                aria-label="Ativar notificações de compras de planos"
              >
                <input type="checkbox" checked />
                <span class="slider-toggle"></span>
              </label>
            </article>

            <article class="config-item">
              <section class="config-item-esquerda">
                <figure class="config-icone" aria-hidden="true">
                  <i class="bi bi-calendar-event-fill"></i>
                </figure>
                <section>
                  <span class="config-nome">Lembretes de agenda</span>
                  <span class="config-desc"
                    >Alertas sobre consultas e retornos</span
                  >
                </section>
              </section>
              <label class="toggle" aria-label="Ativar lembretes de agenda">
                <input type="checkbox" checked />
                <span class="slider-toggle"></span>
              </label>
            </article>
          </section>

          <section class="config-grupo" aria-labelledby="grupo-perigo">
            <h2 class="config-grupo-titulo" id="grupo-perigo">
              Zona de perigo
            </h2>

            <article class="config-item config-item-perigo">
              <section class="config-item-esquerda">
                <figure class="config-icone perigo" aria-hidden="true">
                  <i class="bi bi-box-arrow-right"></i>
                </figure>
                <section>
                  <span class="config-nome">Sair da conta</span>
                  <span class="config-desc"
                    >Encerre a sessão do painel profissional</span
                  >
                </section>
              </section>
              <a href="/logout" aria-label="Sair da conta">
                <i
                  class="bi bi-chevron-right config-seta"
                  aria-hidden="true"
                ></i>
              </a>
            </article>
          </section>

          <button
            class="btn-salvar-config"
            onclick="salvarConfigs()"
            type="button"
          >
            Salvar configurações
          </button>
          <p class="msg-salvo" id="msgSalvo" role="status">
            ✅ Configurações salvas!
          </p>
        </section>
      </main>
    </div>

    <%- include('../../partials/footer.ejs') %>

    <style>
      .pro-config-shell {
        display: flex;
        min-height: calc(100vh - 72px);
      }

      .pro-config-main {
        flex: 1;
        min-width: 0;
      }

      .pro-config-main .config-main {
        max-width: 980px;
        padding-top: 1.2rem;
      }

      .pro-config-hero {
        background: linear-gradient(135deg, #0c4f43, #1a8a75);
        border-radius: 16px;
        padding: 1.2rem 1.35rem;
        color: #fff;
        margin-bottom: 1.25rem;
        box-shadow: 0 12px 32px rgba(12, 79, 67, 0.16);
      }

      .pro-config-hero h2 {
        margin: 0 0 0.35rem;
        font-size: 1.05rem;
        font-weight: 800;
      }

      .pro-config-hero p {
        margin: 0;
        font-size: 0.9rem;
        opacity: 0.9;
        line-height: 1.45;
      }

      .config-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .config-resumo {
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.9rem;
        box-shadow: 0 2px 10px rgba(12, 79, 67, 0.05);
      }

      .config-resumo .config-icone {
        background: rgba(26, 138, 117, 0.12);
      }

      .config-resumo strong {
        display: block;
        font-size: 0.92rem;
        color: var(--fundoclaro);
        margin-bottom: 0.15rem;
      }

      .config-resumo span {
        font-size: 0.78rem;
        color: var(--muted);
      }

      @media (max-width: 860px) {
        .pro-config-shell {
          display: block;
        }

        .pro-config-main .config-main {
          padding-inline: 1rem;
          padding-bottom: 5rem;
        }

        .config-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
