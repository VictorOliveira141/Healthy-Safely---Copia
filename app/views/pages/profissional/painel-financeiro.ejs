<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Painel Financeiro | Healthy Safely - Hábitos Saudáveis</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
  </head>
  <body>
    <%- include("../../partials/header.ejs") %>

    <div class="pro-wrapper">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="pro-main">
        <h1 class="pro-page-title">
          <i class="bi bi-bar-chart-line-fill"></i> Painel Financeiro
        </h1>

        <!-- ── Stats ── -->
        <section class="pro-stats-grid" aria-label="Resumo financeiro">
          <article class="pro-stat-card">
            <p class="pro-stat-label">
              <i class="bi bi-cash-coin"></i> Receita total
            </p>
            <p class="pro-stat-value">R$ <%= usuario.receita || 0 %></p>
          </article>
          <article class="pro-stat-card">
            <p class="pro-stat-label">
              <i class="bi bi-people-fill"></i> Compradores
            </p>
            <p class="pro-stat-value"><%= usuario.compradores || 0 %></p>
          </article>
          <article class="pro-stat-card">
            <p class="pro-stat-label">
              <i class="bi bi-bag-heart-fill"></i> Planos ativos
            </p>
            <p class="pro-stat-value"><%= usuario.planos || 0 %></p>
          </article>
          <article class="pro-stat-card">
            <p class="pro-stat-label">
              <i class="bi bi-graph-up-arrow"></i> Este mês
            </p>
            <p class="pro-stat-value"><%= usuario.receitames || 0 %></p>
          </article>
        </section>

        <!-- ── Gráfico de barras simples ── -->
        <section class="pro-section" style="margin-bottom: 1.5rem">
          <div class="pro-section-header">
            <h2 class="pro-section-title">Receita dos últimos 6 meses</h2>
          </div>
          <div
            style="
              display: flex;
              align-items: flex-end;
              gap: 0.75rem;
              height: 130px;
              padding: 0.5rem 0 0;
            "
            id="grafico-barras"
            aria-label="Gráfico de receita mensal"
          ></div>
          <div
            style="display: flex; gap: 0.75rem; margin-top: 0.5rem"
            id="grafico-labels"
          ></div>
        </section>

        <!-- ── Últimas compras ── -->
        <section class="pro-section">
          <div class="pro-section-header">
            <h2 class="pro-section-title">Últimas compras de planos</h2>
            <span class="badge badge-green">Atualizado agora</span>
          </div>
          <div class="pro-table-wrap">
            <table class="pro-table">
              <thead>
                <tr>
                  <th>Usuário</th>
                  <th>Plano</th>
                  <th>Data</th>
                  <th>Valor</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td data-label="Usuário" style="color: var(--fundoclaro)">
                    Victor Hugo
                  </td>
                  <td data-label="Plano" style="color: var(--fundoclaro)">
                    Dieta Emagrecimento
                  </td>
                  <td data-label="Data" style="color: var(--fundoclaro)">
                    18/04/2026
                  </td>
                  <td data-label="Valor" style="color: var(--fundoclaro)">
                    R$ 89,90
                  </td>
                  <td data-label="Status">
                    <span class="badge badge-green"
                      ><i class="bi bi-check-circle-fill"></i> Aprovado</span
                    >
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- ── Planos mais vendidos ── -->
        <section class="pro-section">
          <div class="pro-section-header">
            <h2 class="pro-section-title">Planos mais vendidos</h2>
            <a
              href="/profissional/planos"
              class="pro-btn pro-btn-ghost"
              style="font-size: 0.8rem; padding: 0.45rem 0.9rem"
            >
              <i class="bi bi-arrow-right"></i> Ver todos
            </a>
          </div>
          <div
            style="display: flex; flex-direction: column; gap: 0.65rem"
            id="lista-top-planos"
          >
            <!-- gerado via JS -->
          </div>
        </section>
      </main>
    </div>

    <%- include("../../partials/footer.ejs") %>
    <script src="/js/darkmode.js"></script>
    <script>
      /* ── Gráfico de barras inline ── */
      (function () {
        const dados = [
          { mes: "Nov", val: 100 },
          { mes: "Dez", val: 100 },
          { mes: "Jan", val: 100 },
          { mes: "Fev", val: 100 },
          { mes: "Mar", val: 100 },
          { mes: "Abr", val: 100 },
        ];
        const max = Math.max(...dados.map((d) => d.val));
        const cont = document.getElementById("grafico-barras");
        const labels = document.getElementById("grafico-labels");

        dados.forEach((d) => {
          const pct = (d.val / max) * 100;
          const wrap = document.createElement("div");
          wrap.style.cssText =
            "flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end;";
          wrap.innerHTML = `
      <span style="font-size:.7rem;font-weight:700;color:var(--fundoclaro)">${d.val >= 1000 ? (d.val / 1000).toFixed(1) + "k" : d.val}</span>
      <div style="width:100%;height:${pct}%;background: var(--accent-color);border-radius:6px 6px 0 0;transition:opacity .2s;" title="R$ ${d.val}"></div>
    `;
          cont.appendChild(wrap);

          const lbl = document.createElement("div");
          lbl.style.cssText =
            "flex:1;text-align:center;font-size:.72rem;font-weight:600;color: var(--fundoclaro);";
          lbl.textContent = d.mes;
          labels.appendChild(lbl);
        });
      })();

      /* ── Top planos ── */
      (function () {
        const planos = [
          { nome: "Dieta Emagrecimento", vendas: 1, receita: "R$ 100" },
        ];

        const maxVendas = Math.max(...planos.map((p) => p.vendas));
        const cont = document.getElementById("lista-top-planos");
        planos.forEach((p, i) => {
          const pct = Math.round((p.vendas / maxVendas) * 100);
          const el = document.createElement("div");
          el.style.cssText = "display:flex;align-items:center;gap:1rem;";
          el.innerHTML = `
      <span style="font-size:.75rem;font-weight:800;color:var(--fundoclaro);width:16px;text-align:center;">${i + 1}</span>
      <div style="flex:1;">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <span style="font-size:.85rem;font-weight:600;color:var(--fundoclaro)">${p.nome}</span>
          <span style="font-size:.75rem;font-weight:700;color:var(--fundoclaro)">${p.receita}</span>
        </div>
        <div style="height:5px;background:var(--border);border-radius:99px;overflow:hidden;">
          <div style="height:100%;width:${pct}%;background: var(--accent-color);border-radius:99px;"></div>
        </div>
        <span style="font-size:.68rem;color:var(--fundoclaro);margin-top:3px;display:block">${p.vendas} compras</span>
      </div>
    `;
          cont.appendChild(el);
        });
      })();
    </script>
  </body>
</html>
