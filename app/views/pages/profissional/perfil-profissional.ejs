<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Meu perfil profissional no Healthy Safely: dados de conta, atuação e atalhos rápidos para gestão de pacientes e planos."
    />
    <title>Meu Perfil Profissional | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <%- include("../../partials/header.ejs") %>

    <%
      const prof = colaborador || usuario || {};
      const nomeCompleto = prof.nome || "Profissional";
      const nomeCurto = nomeCompleto.split(" ").slice(0, 2).join(" ");
      const iniciais = nomeCompleto
        .split(" ")
        .filter(Boolean)
        .slice(0, 2)
        .map((p) => p[0])
        .join("")
        .toUpperCase() || "PR";
      const dataCadastro = prof.criado_em
        ? new Date(prof.criado_em).toLocaleDateString("pt-BR", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
          })
        : "Nao informado";
    %>

    <div class="pro-wrapper">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="pro-main">
        <h1 class="pro-page-title">
          <i class="bi bi-person-badge-fill"></i> Meu Perfil Profissional
        </h1>

        <section class="perfil-grid" aria-label="Perfil profissional">
          <article class="perfil-card perfil-identidade">
            <figure class="perfil-avatar" aria-hidden="true"><%= iniciais %></figure>

            <section>
              <h2><%= nomeCurto %></h2>
              <p><%= prof.email || "email nao informado" %></p>
            </section>

            <section class="perfil-badges" aria-label="Tags de perfil">
              <span class="perfil-badge">
                <i class="bi bi-shield-check"></i> Conta profissional
              </span>
              <span class="perfil-badge">
                <i class="bi bi-award"></i> Nivel: <%= prof.nivel || "profissional" %>
              </span>
            </section>

            <nav class="perfil-acoes" aria-label="Acoes rapidas do profissional">
              <a href="/profissional/configuracoes" class="perfil-link">
                <span><i class="bi bi-gear-fill"></i> Configuracoes</span>
                <i class="bi bi-chevron-right"></i>
              </a>
              <a href="/profissional/planos" class="perfil-link">
                <span><i class="bi bi-bag-heart-fill"></i> Meus planos</span>
                <i class="bi bi-chevron-right"></i>
              </a>
              <a href="/profissional/pacientes" class="perfil-link">
                <span><i class="bi bi-people-fill"></i> Pacientes</span>
                <i class="bi bi-chevron-right"></i>
              </a>
            </nav>
          </article>

          <article class="perfil-card perfil-detalhes">
            <h3>Informacoes da conta</h3>

            <section class="perfil-linha">
              <span class="perfil-label">Nome completo</span>
              <span class="perfil-valor"><%= nomeCompleto %></span>
            </section>

            <section class="perfil-linha">
              <span class="perfil-label">E-mail</span>
              <span class="perfil-valor"><%= prof.email || "Nao informado" %></span>
            </section>

            <section class="perfil-linha">
              <span class="perfil-label">Tipo de conta</span>
              <span class="perfil-valor"><%= prof.tipo || "profissional" %></span>
            </section>

            <section class="perfil-linha">
              <span class="perfil-label">Nivel</span>
              <span class="perfil-valor"><%= prof.nivel || "profissional" %></span>
            </section>

            <section class="perfil-linha">
              <span class="perfil-label">Data de cadastro</span>
              <span class="perfil-valor"><%= dataCadastro %></span>
            </section>

            <p class="perfil-nota">
              Esta pagina mostra os dados principais da sua conta profissional.
              Para alterar preferencias de uso e notificacoes, acesse a area de
              configuracoes.
            </p>
          </article>
        </section>
      </main>
    </div>

    <%- include("../../partials/footer.ejs") %>
    <style>
      .perfil-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1rem;
      }

      .perfil-card {
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        box-shadow: var(--pro-shadow);
      }

      .perfil-identidade {
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .perfil-avatar {
        width: 82px;
        height: 82px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0c4f43, #1a8a75);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: 800;
        border: 3px solid #fff;
        box-shadow: 0 6px 16px rgba(12, 79, 67, 0.18);
      }

      .perfil-identidade h2 {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--fundoclaro);
        margin: 0;
      }

      .perfil-identidade p {
        margin: 0;
        color: var(--muted);
        font-size: 0.85rem;
      }

      .perfil-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .perfil-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.28rem 0.6rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        background: rgba(52, 211, 153, 0.14);
        color: #0f766e;
      }

      html.dark .perfil-badge {
        color: #34d399;
      }

      .perfil-acoes {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .perfil-link {
        text-decoration: none;
        color: var(--fundoclaro);
        font-size: 0.82rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.55rem 0.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: background 0.18s;
      }

      .perfil-link:hover {
        background: rgba(26, 138, 117, 0.1);
      }

      .perfil-detalhes {
        padding: 1.2rem;
      }

      .perfil-detalhes h3 {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--fundoclaro);
        margin: 0 0 0.8rem;
      }

      .perfil-linha {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 0.75rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--border);
      }

      .perfil-linha:last-child {
        border-bottom: none;
      }

      .perfil-label {
        font-size: 0.75rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-weight: 700;
      }

      .perfil-valor {
        font-size: 0.88rem;
        color: var(--fundoclaro);
        font-weight: 600;
        word-break: break-word;
      }

      .perfil-nota {
        margin-top: 0.9rem;
        padding: 0.8rem 0.9rem;
        border-radius: 10px;
        border: 1px dashed var(--border);
        color: var(--muted);
        font-size: 0.8rem;
        line-height: 1.5;
      }

      @media (max-width: 980px) {
        .perfil-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .pro-main {
          padding: 1rem;
          padding-bottom: 5rem;
        }

        .perfil-linha {
          grid-template-columns: 1fr;
          gap: 0.3rem;
        }
      }
    </style>
  </body>
</html>
