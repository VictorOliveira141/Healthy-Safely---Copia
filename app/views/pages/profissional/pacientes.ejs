<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pacientes | Área Profissional - Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
    <link rel="stylesheet" href="/css/global.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <style>
      .pacientes-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .pacientes-toolbar h1 {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--fundoclaro);
        margin: 0;
      }

      .toolbar-acoes {
        display: flex;
        gap: 0.6rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .input-busca {
        padding: 0.5rem 0.85rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: var(--font-text);
        color: var(--fundoclaro);
        background: var(--primary-color);
        min-width: 200px;
      }

      .input-busca:focus {
        outline: none;
        border-color: var(--accent-color);
      }

      .btn-novo-paciente {
        padding: 0.5rem 1rem;
        background: var(--secondary-color);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: var(--font-text);
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: opacity 0.2s;
      }

      .btn-novo-paciente:hover { opacity: 0.88; }

      .pacientes-lista {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .paciente-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        transition: box-shadow 0.15s;
      }

      .paciente-card:hover {
        box-shadow: 0 4px 14px rgba(12,79,67,0.08);
      }

      .paciente-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #e6f4f1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: var(--secondary-color);
        font-weight: 700;
        flex-shrink: 0;
      }

      .paciente-info {
        flex: 1;
      }

      .paciente-info strong {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--fundoclaro);
        margin-bottom: 2px;
      }

      .paciente-info span {
        font-size: var(--font-text);
        color: var(--muted);
      }

      .paciente-status {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
      }

      .paciente-status.ativo {
        background: #e6f4f1;
        color: #0c7a65;
      }

      .paciente-status.inativo {
        background: #f5f5f5;
        color: #888;
      }

      .paciente-status.novo {
        background: #fff8e1;
        color: #b36a00;
      }

      .paciente-acoes {
        display: flex;
        gap: 0.4rem;
      }

      .btn-acao {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        font-size: 0.9rem;
        transition: background 0.15s, color 0.15s;
      }

      .btn-acao:hover {
        background: #e6f4f1;
        color: var(--secondary-color);
        border-color: var(--accent-color);
      }

      .pacientes-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      @media (max-width: 600px) {
        .pacientes-stats { grid-template-columns: 1fr; }
        .paciente-acoes { display: none; }
      }

      .stat-card-mini {
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        padding: 1rem;
        text-align: center;
      }

      .stat-card-mini strong {
        display: block;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--secondary-color);
      }

      .stat-card-mini span {
        font-size: var(--font-text);
        color: var(--muted);
      }

      .vazio-estado {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--muted);
        border: 1px dashed var(--border);
        border-radius: var(--border-radius);
      }

      .vazio-estado i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.75rem;
        opacity: 0.4;
      }
    </style>
  </head>
  <body>
    <%- include('../../partials/header.ejs') %>
    <%- include('../../partials/menu-inferior.ejs') %>

    <section class="admin-container">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="admin-main" aria-labelledby="titulo-pacientes">

        <header class="pacientes-toolbar">
          <h1 id="titulo-pacientes">
            <i class="bi bi-people-fill" aria-hidden="true"></i>
            Meus Pacientes
          </h1>
          <section class="toolbar-acoes">
            <label for="buscaPaciente" class="visually-hidden">Buscar paciente</label>
            <input
              type="search"
              id="buscaPaciente"
              class="input-busca"
              placeholder="Buscar paciente..."
              oninput="filtrarPacientes(this.value)"
              aria-label="Buscar paciente pelo nome"
            />
            <button class="btn-novo-paciente" type="button" onclick="abrirModalNovo()">
              <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
              Novo vínculo
            </button>
          </section>
        </header>

        <section class="pacientes-stats" aria-label="Estatísticas de pacientes">
          <article class="stat-card-mini">
            <strong id="totalPacientes">5</strong>
            <span>Total de pacientes</span>
          </article>
          <article class="stat-card-mini">
            <strong id="pacientesAtivos">4</strong>
            <span>Ativos</span>
          </article>
          <article class="stat-card-mini">
            <strong id="pacientesNovos">1</strong>
            <span>Novos este mês</span>
          </article>
        </section>

        <section class="pacientes-lista" id="listaPacientes" aria-label="Lista de pacientes" aria-live="polite">

          <article class="paciente-card" data-nome="kauã mauricio">
            <figure class="paciente-avatar" aria-hidden="true">KM</figure>
            <section class="paciente-info">
              <strong>Kauã Mauricio</strong>
              <span>Acompanhamento físico · Último contato: 12/03/2026</span>
            </section>
            <span class="paciente-status ativo">Ativo</span>
            <nav class="paciente-acoes" aria-label="Ações para Kauã Mauricio">
              <button class="btn-acao" title="Ver progresso" aria-label="Ver progresso de Kauã Mauricio" type="button">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Enviar mensagem" aria-label="Enviar mensagem para Kauã Mauricio" type="button">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Agendar consulta" aria-label="Agendar consulta com Kauã Mauricio" type="button">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i>
              </button>
            </nav>
          </article>

          <article class="paciente-card" data-nome="daniel renovato">
            <figure class="paciente-avatar" aria-hidden="true">DR</figure>
            <section class="paciente-info">
              <strong>Daniel Renovato</strong>
              <span>Nutrição esportiva · Último contato: 10/03/2026</span>
            </section>
            <span class="paciente-status ativo">Ativo</span>
            <nav class="paciente-acoes" aria-label="Ações para Daniel Renovato">
              <button class="btn-acao" title="Ver progresso" aria-label="Ver progresso de Daniel Renovato" type="button">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Enviar mensagem" aria-label="Enviar mensagem para Daniel Renovato" type="button">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Agendar consulta" aria-label="Agendar consulta com Daniel Renovato" type="button">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i>
              </button>
            </nav>
          </article>

          <article class="paciente-card" data-nome="mateus felipe">
            <figure class="paciente-avatar" aria-hidden="true">MF</figure>
            <section class="paciente-info">
              <strong>Mateus Felipe</strong>
              <span>Avaliação física · Último contato: 16/03/2026</span>
            </section>
            <span class="paciente-status ativo">Ativo</span>
            <nav class="paciente-acoes" aria-label="Ações para Mateus Felipe">
              <button class="btn-acao" title="Ver progresso" type="button" aria-label="Ver progresso de Mateus Felipe">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Enviar mensagem" type="button" aria-label="Enviar mensagem para Mateus Felipe">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Agendar consulta" type="button" aria-label="Agendar consulta com Mateus Felipe">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i>
              </button>
            </nav>
          </article>

          <article class="paciente-card" data-nome="ana clara souza">
            <figure class="paciente-avatar" aria-hidden="true">AS</figure>
            <section class="paciente-info">
              <strong>Ana Clara Souza</strong>
              <span>Saúde mental · Último contato: 20/03/2026</span>
            </section>
            <span class="paciente-status novo">Novo</span>
            <nav class="paciente-acoes" aria-label="Ações para Ana Clara Souza">
              <button class="btn-acao" title="Ver progresso" type="button" aria-label="Ver progresso de Ana Clara Souza">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Enviar mensagem" type="button" aria-label="Enviar mensagem para Ana Clara Souza">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Agendar consulta" type="button" aria-label="Agendar consulta com Ana Clara Souza">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i>
              </button>
            </nav>
          </article>

          <article class="paciente-card" data-nome="pedro henrique lima">
            <figure class="paciente-avatar" aria-hidden="true">PL</figure>
            <section class="paciente-info">
              <strong>Pedro Henrique Lima</strong>
              <span>Condicionamento físico · Último contato: 05/03/2026</span>
            </section>
            <span class="paciente-status inativo">Inativo</span>
            <nav class="paciente-acoes" aria-label="Ações para Pedro Henrique Lima">
              <button class="btn-acao" title="Ver progresso" type="button" aria-label="Ver progresso de Pedro Henrique Lima">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Enviar mensagem" type="button" aria-label="Enviar mensagem para Pedro Henrique Lima">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
              </button>
              <button class="btn-acao" title="Agendar consulta" type="button" aria-label="Agendar consulta com Pedro Henrique Lima">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i>
              </button>
            </nav>
          </article>

        </section>

      </main>
    </section>

    <%- include('../../partials/footer.ejs') %>

    <style>
      .visually-hidden { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
    </style>

    <script>
      function filtrarPacientes(termo) {
        const cards = document.querySelectorAll('.paciente-card');
        const t = termo.toLowerCase().trim();
        let visiveis = 0;
        cards.forEach(card => {
          const nome = card.dataset.nome || '';
          const visivel = !t || nome.includes(t);
          card.style.display = visivel ? 'flex' : 'none';
          if (visivel) visiveis++;
        });
      }

      function abrirModalNovo() {
        alert('Funcionalidade de vínculo com paciente será implementada com banco de dados.');
      }
    </script>
  </body>
</html>
