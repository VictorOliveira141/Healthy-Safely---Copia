<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <script src="/js/darkmode.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Meus Planos | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/profissional/planos.css" />
    <link rel="stylesheet" href="/css/profissional/painel-financeiro.css" />
  </head>
  <body>
    <%- include("../../partials/header.ejs") %>

    <div class="pro-wrapper">
      <%- include('../../partials/adm/sidebar-profissional.ejs') %>

      <main class="pro-main">
        <article class="planos-toolbar">
          <h1 class="pro-page-title" style="margin: 0">
            <i class="bi bi-bag-heart-fill"></i> Meus Planos
          </h1>
          <button class="pro-btn" onclick="abrirModalCriar()" type="button">
            <i class="bi bi-plus-circle-fill"></i> Criar plano
          </button>
        </article>

        <p
          style="
            font-size: 0.85rem;
            color: var(--fundoclaro);
            margin-bottom: 1.5rem;
            max-width: 520px;
          "
        >
          Crie planos de saúde, dieta ou treino para vender aos usuários. Após a
          compra, o usuário desbloqueia o plano para sempre e pode seguir as
          tarefas semanalmente.
        </p>

        <!-- Grid de planos -->
        <section
          class="planos-grid"
          id="planosGrid"
          aria-label="Planos cadastrados"
        >
          <!-- renderizado via JS -->
        </section>

        <article class="planos-vazio" id="planosVazio" style="display: none">
          <i class="bi bi-bag-heart"></i>
          <p style="font-weight: 700; font-size: 1rem; margin-bottom: 0.35rem">
            Nenhum plano criado
          </p>
          <p style="font-size: 0.85rem">
            Crie seu primeiro plano e comece a vender para os usuários.
          </p>
          <button
            class="pro-btn"
            onclick="abrirModalCriar()"
            style="margin-top: 1rem"
          >
            <i class="bi bi-plus-circle-fill"></i> Criar primeiro plano
          </button>
        </article>
      </main>
    </div>

    <!-- ── Modal criar/editar plano ── -->
    <div
      class="pro-modal-overlay"
      id="modalOverlay"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modalTitulo"
    >
      <div class="pro-modal">
        <div class="pro-modal-header">
          <h2 id="modalTitulo">Novo plano</h2>
          <button
            class="pro-modal-close"
            onclick="fecharModal()"
            aria-label="Fechar"
          >
            &times;
          </button>
        </div>
        <div class="pro-modal-body">
          <div class="form-row-2">
            <div class="pro-field">
              <label class="pro-label">Nome do plano *</label>
              <input
                type="text"
                id="inpNome"
                class="pro-input"
                placeholder="Ex: Dieta Emagrecimento"
                maxlength="80"
              />
            </div>
            <div class="pro-field">
              <label class="pro-label">Categoria *</label>
              <select id="inpCategoria" class="pro-select">
                <option value="alimentacao">🥗 Alimentação</option>
                <option value="treino">💪 Treino</option>
                <option value="saude">❤️ Saúde</option>
                <option value="sono">🌙 Sono</option>
                <option value="mental">🧠 Saúde Mental</option>
                <option value="outro">✨ Outro</option>
              </select>
            </div>
          </div>

          <div class="form-row-2">
            <div class="pro-field">
              <label class="pro-label">Preço (R$) *</label>
              <input
                type="number"
                id="inpPreco"
                class="pro-input"
                placeholder="Ex: 89.90"
                min="0"
                step="0.01"
              />
            </div>
            <div class="pro-field">
              <label class="pro-label">Duração da semana</label>
              <select id="inpDuracao" class="pro-select">
                <option value="semanal">Semanal (renovável)</option>
                <option value="4semanas">4 semanas</option>
                <option value="8semanas">8 semanas</option>
                <option value="12semanas">12 semanas</option>
                <option value="permanente">Permanente</option>
              </select>
            </div>
          </div>

          <div class="pro-field">
            <label class="pro-label">Descrição</label>
            <textarea
              id="inpDesc"
              class="pro-textarea"
              placeholder="Descreva o que o usuário vai ganhar com esse plano..."
            ></textarea>
          </div>

          <div class="pro-field">
            <label class="pro-label">Tarefas semanais do plano</label>
            <div class="tarefas-builder">
              <div class="tarefas-builder-header">
                <i class="bi bi-list-check"></i>
                Tarefas que o usuário vai receber toda semana
              </div>
              <div class="tarefas-builder-lista" id="tarefasLista"></div>
              <div class="tarefas-builder-add">
                <input
                  type="text"
                  id="inpNovaTarefa"
                  placeholder="Nova tarefa..."
                  maxlength="120"
                  onkeydown="
                    if (event.key === 'Enter') {
                      event.preventDefault();
                      adicionarTarefa();
                    }
                  "
                />
                <button
                  class="btn-add-tarefa"
                  onclick="adicionarTarefa()"
                  type="button"
                >
                  + Adicionar
                </button>
              </div>
            </div>
          </div>

          <p
            id="modalErro"
            style="color: #dc2626; font-size: 0.82rem; display: none"
          ></p>
        </div>
        <div class="pro-modal-footer">
          <button
            class="pro-btn pro-btn-ghost"
            onclick="fecharModal()"
            type="button"
          >
            Cancelar
          </button>
          <button
            class="pro-btn"
            onclick="salvarPlano()"
            id="btnSalvar"
            type="button"
          >
            <i class="bi bi-check2-circle"></i> Salvar plano
          </button>
        </div>
      </div>
    </div>

    <%- include("../../partials/footer.ejs") %>

    <script src="/js/planos.js"></script>
  </body>
</html>
