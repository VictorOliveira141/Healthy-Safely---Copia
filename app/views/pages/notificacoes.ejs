<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notificações | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/global.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <style>
      .notif-main {
        max-width: 680px;
        margin: 0 auto;
        padding: 2rem 1.25rem 6rem;
      }

      .notif-topo {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .notif-topo h1 {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--fundoclaro);
      }

      .btn-marcar-todas {
        font-size: var(--font-text);
        color: var(--accent-color);
        background: none;
        border: none;
        cursor: pointer;
        font-weight: 600;
        padding: 0;
      }

      .notif-filtros {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }

      .filtro-btn {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: var(--primary-color);
        font-size: var(--font-text);
        color: var(--muted);
        cursor: pointer;
        font-weight: 500;
        transition: all 0.15s;
      }

      .filtro-btn.ativo {
        background: var(--secondary-color);
        color: #fff;
        border-color: var(--secondary-color);
      }

      .notif-lista {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 1.2rem;
        background: var(--primary-color);
        border: 1px solid var(--border);
        border-radius: var(--border-radius);
        transition: background 0.15s;
        position: relative;
      }

      .notif-item.nao-lida {
        border-left: 3px solid var(--accent-color);
        background: #f0faf7;
      }

      .notif-icone {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
      }

      .notif-icone.tarefa   { background: #e6f4f1; color: var(--secondary-color); }
      .notif-icone.conquista { background: #fff8e1; color: #f59e0b; }
      .notif-icone.sistema  { background: #f0f4ff; color: #4f63d2; }
      .notif-icone.lembrete { background: #fef0f0; color: #e55353; }

      .notif-corpo {
        flex: 1;
      }

      .notif-corpo strong {
        display: block;
        font-size: 0.875rem;
        color: var(--fundoclaro);
        margin-bottom: 2px;
      }

      .notif-corpo p {
        font-size: var(--font-text);
        color: var(--muted);
        margin: 0;
        line-height: 1.5;
      }

      .notif-tempo {
        font-size: 10px;
        color: var(--muted);
        white-space: nowrap;
        margin-top: 2px;
      }

      .notif-ponto {
        width: 8px;
        height: 8px;
        background: var(--accent-color);
        border-radius: 50%;
        position: absolute;
        top: 1rem;
        right: 1rem;
      }

      .notif-vazia {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--muted);
      }

      .notif-vazia i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.75rem;
        opacity: 0.4;
      }

      .notif-vazia p {
        font-size: var(--font-text);
      }

      .notif-grupo-data {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--muted);
        margin: 1.25rem 0 0.5rem;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <%- include('../partials/menu-inferior.ejs') %>

    <main class="notif-main" aria-labelledby="titulo-notif">
      <header class="notif-topo">
        <h1 id="titulo-notif">
          <i class="bi bi-bell-fill" aria-hidden="true"></i>
          Notificações
        </h1>
        <button class="btn-marcar-todas" onclick="marcarTodas()" type="button">
          Marcar todas como lidas
        </button>
      </header>

      <nav class="notif-filtros" aria-label="Filtrar notificações">
        <button class="filtro-btn ativo" data-filtro="todas" onclick="filtrar(this, 'todas')">Todas</button>
        <button class="filtro-btn" data-filtro="nao-lidas" onclick="filtrar(this, 'nao-lidas')">Não lidas</button>
        <button class="filtro-btn" data-filtro="tarefas" onclick="filtrar(this, 'tarefas')">Tarefas</button>
        <button class="filtro-btn" data-filtro="conquistas" onclick="filtrar(this, 'conquistas')">Conquistas</button>
      </nav>

      <section class="notif-lista" id="listaNotificacoes" aria-live="polite" aria-label="Lista de notificações">

        <p class="notif-grupo-data">Hoje</p>

        <article class="notif-item nao-lida" data-tipo="tarefa">
          <figure class="notif-icone tarefa" aria-hidden="true">
            <i class="bi bi-check-circle-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>Tarefa pendente: Beber 2L de água</strong>
            <p>Você ainda não completou sua meta de hidratação de hoje.</p>
            <time class="notif-tempo" datetime="2026-03-30T09:00">Há 2 horas</time>
          </section>
          <span class="notif-ponto" aria-label="Não lida"></span>
        </article>

        <article class="notif-item nao-lida" data-tipo="conquista">
          <figure class="notif-icone conquista" aria-hidden="true">
            <i class="bi bi-trophy-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>🎉 Nova medalha conquistada!</strong>
            <p>Parabéns! Você ganhou a medalha <em>Corredor Nível 1</em> por completar 10km.</p>
            <time class="notif-tempo" datetime="2026-03-30T08:00">Há 3 horas</time>
          </section>
          <span class="notif-ponto" aria-label="Não lida"></span>
        </article>

        <article class="notif-item" data-tipo="sistema">
          <figure class="notif-icone sistema" aria-hidden="true">
            <i class="bi bi-info-circle-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>Atualização da plataforma</strong>
            <p>Novos recursos foram adicionados ao seu painel. Confira o que há de novo!</p>
            <time class="notif-tempo" datetime="2026-03-30T07:00">Há 4 horas</time>
          </section>
        </article>

        <p class="notif-grupo-data">Ontem</p>

        <article class="notif-item" data-tipo="tarefa">
          <figure class="notif-icone tarefa" aria-hidden="true">
            <i class="bi bi-check-circle-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>Tarefa concluída: Sono de qualidade</strong>
            <p>Você dormiu 8 horas ontem. Continue assim! 💤</p>
            <time class="notif-tempo" datetime="2026-03-29T08:00">Ontem às 08h</time>
          </section>
        </article>

        <article class="notif-item" data-tipo="lembrete">
          <figure class="notif-icone lembrete" aria-hidden="true">
            <i class="bi bi-alarm-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>Lembrete: Exercício físico</strong>
            <p>Não esqueça de registrar sua atividade física de hoje.</p>
            <time class="notif-tempo" datetime="2026-03-29T17:00">Ontem às 17h</time>
          </section>
        </article>

        <p class="notif-grupo-data">Esta semana</p>

        <article class="notif-item" data-tipo="conquista">
          <figure class="notif-icone conquista" aria-hidden="true">
            <i class="bi bi-star-fill"></i>
          </figure>
          <section class="notif-corpo">
            <strong>Você subiu de nível!</strong>
            <p>Parabéns por chegar ao Nível 2 na plataforma Healthy Safely.</p>
            <time class="notif-tempo" datetime="2026-03-28T12:00">28/03 às 12h</time>
          </section>
        </article>

      </section>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      function filtrar(btn, tipo) {
        document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('ativo'));
        btn.classList.add('ativo');

        const itens = document.querySelectorAll('.notif-item');
        itens.forEach(item => {
          if (tipo === 'todas') {
            item.style.display = 'flex';
          } else if (tipo === 'nao-lidas') {
            item.style.display = item.classList.contains('nao-lida') ? 'flex' : 'none';
          } else {
            item.style.display = item.dataset.tipo === tipo ? 'flex' : 'none';
          }
        });
      }

      function marcarTodas() {
        document.querySelectorAll('.notif-item.nao-lida').forEach(item => {
          item.classList.remove('nao-lida');
          const ponto = item.querySelector('.notif-ponto');
          if (ponto) ponto.remove();
        });
      }
    </script>
  </body>
</html>
