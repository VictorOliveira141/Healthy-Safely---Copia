<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notificações | Healthy Safely</title>
    <meta property="og:title" content="Notificações | Healthy Safely" />
    <meta property="og:description" content="Fique por dentro das notificações e atualizações da sua conta no Healthy Safely." />
    <meta property="og:image" content="/imagem/Logo repaginado 2.png" />
    <meta property="og:url" content="https://healthysafely.com/notificacoes" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Healthy Safely" />
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/notificacoes.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>

    <main class="notif-main" aria-labelledby="titulo-notif">
      <section class="notif-topo">
        <%- include('../partials/botao-voltar.ejs') %>
        <h1 id="titulo-notif">
          <i class="bi bi-bell-fill" aria-hidden="true"></i>
          Notificações
        </h1>
        <form action="/notificacoes/marcar-lidas" method="POST" style="display:inline">
          <button class="btn-marcar-todas" type="submit">
            Marcar todas como lidas
          </button>
        </form>
      </section>

      <nav class="notif-filtros" aria-label="Filtrar notificações">
        <button class="filtro-btn ativo" data-filtro="todas" onclick="filtrar(this,'todas')">Todas</button>
        <button class="filtro-btn" data-filtro="nao-lidas" onclick="filtrar(this,'nao-lidas')">Não lidas</button>
      </nav>

      <section class="notif-lista" id="listaNotificacoes" aria-live="polite" aria-label="Lista de notificações">
        <% if (!notificacoes || !notificacoes.length) { %>
          <section style="text-align:center;padding:3rem;color:var(--muted)">
            <i class="bi bi-bell-slash" style="font-size:2.5rem;display:block;margin-bottom:.75rem;opacity:.3"></i>
            <p style="font-weight:700">Nenhuma notificação ainda</p>
            <p style="font-size:.85rem">As notificações aparecerão aqui conforme você usa a plataforma.</p>
          </section>
        <% } else { %>
          <% notificacoes.forEach(n => { %>
          <article class="notif-item <%= !n.lida ? 'nao-lida' : '' %>" data-tipo="sistema">
            <figure class="notif-icone sistema" aria-hidden="true">
              <i class="bi bi-info-circle-fill"></i>
            </figure>
            <section class="notif-corpo">
              <strong><%= n.mensagem %></strong>
              <time class="notif-tempo" datetime="<%= new Date(n.criado_em).toISOString() %>">
                <%= new Date(n.criado_em).toLocaleString('pt-BR', {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %>
              </time>
            </section>
            <% if (!n.lida) { %><span class="notif-ponto" aria-label="Não lida"></span><% } %>
          </article>
          <% }) %>
        <% } %>
      </section>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      function filtrar(btn, tipo) {
        document.querySelectorAll(".filtro-btn").forEach(b => b.classList.remove("ativo"));
        btn.classList.add("ativo");
        document.querySelectorAll(".notif-item").forEach(item => {
          if (tipo === "todas") item.style.display = "flex";
          else item.style.display = item.classList.contains("nao-lida") ? "flex" : "none";
        });
      }
    </script>
  </body>
</html>
