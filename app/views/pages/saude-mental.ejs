<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saúde Mental | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/pagina-tarefa.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <%- include('../partials/menu-inferior.ejs') %>

    <main class="pt-page">

      <section class="pt-card" aria-labelledby="titulo-saudemental">
        <header class="pt-card-topo">
          <img src="/imagem/saudemental.png" alt="Ícone de saúde mental" />
          <h1 id="titulo-saudemental">Saúde Mental</h1>
        </header>

        <p class="pt-card-texto">
          Pratique 10 minutos de meditação ou respiração consciente por dia
          durante uma semana e registre como se sentiu.<br />
          Um profissional irá acompanhar seu progresso.
        </p>

        <footer class="pt-card-rodape">
          <section class="pt-progresso-bloco">
            <p class="pt-porcentagem-texto" id="porcTexto" aria-live="polite">0% concluída</p>
            <section
              class="pt-barra-track"
              role="progressbar"
              aria-valuenow="0"
              aria-valuemin="0"
              aria-valuemax="100"
              id="barraTrack"
            >
              <section class="pt-barra-fill" id="barraFill"></section>
            </section>
          </section>
          <button class="pt-botao" id="btnAcao" type="button" onclick="registrar()">
            Iniciar prática
          </button>
        </footer>
      </section>

      <section class="pt-secao" aria-labelledby="titulo-dicas-sm">
        <h2 class="pt-secao-titulo" id="titulo-dicas-sm">Dicas para o bem-estar mental</h2>
        <section class="pt-grid">
          <article class="pt-grid-card">
            <i class="bi bi-wind" aria-hidden="true"></i>
            <h4>Respiração 4-7-8</h4>
            <p>Inspire por 4s, segure por 7s e expire por 8s. Reduz a ansiedade em minutos.</p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-journal-text" aria-hidden="true"></i>
            <h4>Diário emocional</h4>
            <p>Escreva 3 coisas pelas quais é grato todo dia para treinar o pensamento positivo.</p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-phone-landscape" aria-hidden="true"></i>
            <h4>Detox digital</h4>
            <p>30 minutos sem telas antes de dormir melhora o sono e reduz o estresse.</p>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-people-fill" aria-hidden="true"></i>
            <h4>Conexão social</h4>
            <p>Fale com alguém de confiança. Relações saudáveis são fundamentais para a saúde mental.</p>
          </article>
        </section>
      </section>

      <nav class="pt-nav-tarefas" aria-label="Navegar entre categorias de saúde">
        <h2 class="pt-nav-titulo">Suas tarefas</h2>
        <section class="pt-nav-grid">
          <a href="/sono" class="pt-nav-item"><img src="/imagem/sono.png" alt="Sono" /><span>Sono</span></a>
          <a href="/saude-mental" class="pt-nav-item ativo" aria-current="page"><img src="/imagem/saudemental.png" alt="Saúde Mental" /><span>Saúde Mental</span></a>
          <a href="/atividade-fisica" class="pt-nav-item"><img src="/imagem/atf.png" alt="Atividade Física" /><span>Atividade Física</span></a>
          <a href="/alimentacao" class="pt-nav-item"><img src="/imagem/alimentacao.png" alt="Alimentação" /><span>Alimentação</span></a>
          <a href="#" class="pt-nav-outros"><img src="/imagem/outros.png" alt="Outros" /><span>Outros</span></a>
        </section>
      </nav>

    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      const CHAVE = 'hs_saudemental_prog';
      let progresso = Number(localStorage.getItem(CHAVE) || 0);
      const btn = document.getElementById('btnAcao');
      const porcTexto = document.getElementById('porcTexto');
      const fill = document.getElementById('barraFill');
      const track = document.getElementById('barraTrack');

      function renderProgresso() {
        fill.style.width = progresso + '%';
        porcTexto.textContent = progresso + '% concluída';
        track.setAttribute('aria-valuenow', progresso);
        if (progresso >= 100) { btn.textContent = '✓ Concluída!'; btn.disabled = true; }
      }

      function registrar() {
        if (progresso >= 100) return;
        progresso = Math.min(progresso + 14, 100);
        localStorage.setItem(CHAVE, progresso);
        renderProgresso();
        if (progresso < 100) btn.textContent = 'Continuar prática';
      }

      renderProgresso();
    </script>
  </body>
</html>
