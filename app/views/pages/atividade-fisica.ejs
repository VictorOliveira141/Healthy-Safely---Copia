<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atividade Física | Healthy Safely</title>
    <link rel="icon" href="/imagem/Logo repaginado 2.png" />
    <link rel="stylesheet" href="/css/pagina-tarefa.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  </head>
  <body>
    <%- include('../partials/header.ejs') %>
    <%- include('../partials/menu-inferior.ejs') %>

    <main class="pt-page">

      <section class="pt-card" aria-labelledby="titulo-atf">
        <header class="pt-card-topo">
          <img src="/imagem/atf.png" alt="Ícone de atividade física" />
          <h1 id="titulo-atf">Atividade Física</h1>
        </header>

        <p class="pt-card-texto">
          Realize no mínimo 30 minutos de atividade física moderada por dia
          durante 7 dias consecutivos e registre sua evolução.<br />
          Um profissional irá acompanhar seu relatório.
        </p>

        <footer class="pt-card-rodape">
          <section class="pt-progresso-bloco">
            <p class="pt-porcentagem-texto" id="porcTexto" aria-live="polite">0% concluída</p>
            <section
              class="pt-barra-track"
              role="progressbar"
              aria-valuenow="0"
              aria-valuemin="0"
              aria-valuemax="100"
              id="barraTrack"
            >
              <section class="pt-barra-fill" id="barraFill"></section>
            </section>
          </section>
          <button class="pt-botao" id="btnAcao" type="button" onclick="registrar()">
            Registrar atividade
          </button>
        </footer>
      </section>

      <section class="pt-secao" aria-labelledby="titulo-treinos">
        <h2 class="pt-secao-titulo" id="titulo-treinos">Sugestões de treino</h2>
        <section class="pt-grid">
          <article class="pt-grid-card">
            <i class="bi bi-person-walking" aria-hidden="true"></i>
            <h4>Caminhada</h4>
            <p>Ideal para iniciantes. Melhora a saúde cardiovascular com baixo impacto.</p>
            <span class="badge-dificuldade">30 min · Fácil</span>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-bicycle" aria-hidden="true"></i>
            <h4>Ciclismo</h4>
            <p>Baixo impacto e ótimo para condicionamento físico e queima calórica.</p>
            <span class="badge-dificuldade">45 min · Moderado</span>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-person-arms-up" aria-hidden="true"></i>
            <h4>Funcional</h4>
            <p>Exercícios com peso corporal para força, resistência e equilíbrio.</p>
            <span class="badge-dificuldade">30 min · Moderado</span>
          </article>
          <article class="pt-grid-card">
            <i class="bi bi-lightning-fill" aria-hidden="true"></i>
            <h4>HIIT</h4>
            <p>Treino intervalado de alta intensidade para queima acelerada de gordura.</p>
            <span class="badge-dificuldade">25 min · Intenso</span>
          </article>
        </section>
      </section>

      <nav class="pt-nav-tarefas" aria-label="Navegar entre categorias de saúde">
        <h2 class="pt-nav-titulo">Suas tarefas</h2>
        <section class="pt-nav-grid">
          <a href="/sono" class="pt-nav-item"><img src="/imagem/sono.png" alt="Sono" /><span>Sono</span></a>
          <a href="/saude-mental" class="pt-nav-item"><img src="/imagem/saudemental.png" alt="Saúde Mental" /><span>Saúde Mental</span></a>
          <a href="/atividade-fisica" class="pt-nav-item ativo" aria-current="page"><img src="/imagem/atf.png" alt="Atividade Física" /><span>Atividade Física</span></a>
          <a href="/alimentacao" class="pt-nav-item"><img src="/imagem/alimentacao.png" alt="Alimentação" /><span>Alimentação</span></a>
          <a href="#" class="pt-nav-outros"><img src="/imagem/outros.png" alt="Outros" /><span>Outros</span></a>
        </section>
      </nav>

    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      const CHAVE = 'hs_atf_prog';
      let progresso = Number(localStorage.getItem(CHAVE) || 0);
      const btn = document.getElementById('btnAcao');
      const porcTexto = document.getElementById('porcTexto');
      const fill = document.getElementById('barraFill');
      const track = document.getElementById('barraTrack');

      function renderProgresso() {
        fill.style.width = progresso + '%';
        porcTexto.textContent = progresso + '% concluída';
        track.setAttribute('aria-valuenow', progresso);
        if (progresso >= 100) { btn.textContent = '✓ Concluída!'; btn.disabled = true; }
      }

      function registrar() {
        if (progresso >= 100) return;
        progresso = Math.min(progresso + 14, 100);
        localStorage.setItem(CHAVE, progresso);
        renderProgresso();
        if (progresso < 100) btn.textContent = 'Registrar novamente';
      }

      renderProgresso();
    </script>
  </body>
</html>
