<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Healthy Safely</title>
  <link rel="icon" href="/imagem/Logo repaginado 2.png" />
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap");

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: "Inter", sans-serif;
      background: #0c4f43;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .admin-login-card {
      background: #fff;
      border-radius: 20px;
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 24px 60px rgba(0,0,0,0.25);
      text-align: center;
    }

    .admin-login-card .logo {
      width: 72px;
      margin-bottom: 20px;
    }

    .admin-login-card h1 {
      font-size: 22px;
      font-weight: 700;
      color: #0c4f43;
      margin-bottom: 6px;
    }

    .admin-login-card p {
      font-size: 13px;
      color: #64748b;
      margin-bottom: 32px;
    }

    .badge-admin {
      display: inline-block;
      background: #0c4f430f;
      color: #0c4f43;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 24px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .campo {
      text-align: left;
      margin-bottom: 20px;
    }

    .campo label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #334155;
      margin-bottom: 6px;
    }

    .campo input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #e2e8f0;
      border-radius: 10px;
      font-size: 14px;
      color: #1e293b;
      background: #f8fafc;
      transition: border-color 0.2s;
      outline: none;
    }

    .campo input:focus {
      border-color: #0c4f43;
      background: #fff;
    }

    .erro-msg {
      background: #fee2e2;
      color: #991b1b;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 13px;
      margin-bottom: 16px;
      text-align: left;
      border-left: 4px solid #ef4444;
    }

    .btn-entrar {
      width: 100%;
      padding: 13px;
      background: #0c4f43;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.2s;
    }

    .btn-entrar:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .voltar-link {
      display: block;
      margin-top: 20px;
      font-size: 13px;
      color: #64748b;
      text-decoration: none;
    }

    .voltar-link:hover { color: #0c4f43; }
  </style>
</head>
<body>

  <div class="admin-login-card">
    <img src="/imagem/Logo repaginado 2.png" alt="Logo Healthy Safely" class="logo" />
    <span class="badge-admin">🔒 Área Restrita</span>
    <h1>Painel Administrativo</h1>
    <p>Digite a senha de acesso para continuar</p>

    <% if (erro) { %>
      <div class="erro-msg">⚠️ <%= erro %></div>
    <% } %>

    <form method="POST" action="/admin">
      <div class="campo">
        <label for="senha">Senha de Administrador</label>
        <input
          type="password"
          id="senha"
          name="senha"
          placeholder="••••••••••••"
          required
          autofocus
        />
      </div>
      <button type="submit" class="btn-entrar">Acessar Painel</button>
    </form>

    <a href="/" class="voltar-link">← Voltar ao site</a>
  </div>

</body>
</html>
