<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
/>
<style>
  .sidebar-profissional {
    
    min-height: 100vh;
    background: var(--secondary-color);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 0;
    flex-shrink: 0;
  }

  .sidebar-logo {
    padding: 0 1.2rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    margin-bottom: 1rem;
  }

  .sidebar-logo img {
    width: 120px;
    filter: brightness(0) invert(1);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0 0.75rem;
    flex: 1;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    color: rgba(255,255,255,0.75);
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }

  .sidebar-link:hover,
  .sidebar-link.ativo {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .sidebar-link i {
    font-size: 1.1rem;
    width: 20px;
    text-align: center;
  }

  .sidebar-divider {
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin: 0.75rem 1rem;
  }

  .sidebar-sair {
    padding: 0 0.75rem 1rem;
  }

  .admin-container {
    display: flex;
    min-height: 100vh;
  }

  .admin-main {
    flex: 1;
    padding: 2rem;
    background: var(--primary-color);
    overflow-y: auto;
  }

  @media (max-width: 768px) {
    .sidebar-profissional {
      display: none;
    }
  }
</style>

<aside class="sidebar-profissional" aria-label="Menu lateral do profissional">
  <figure class="sidebar-logo">
    <img src="/imagem/1x/logozeko.png" alt="Healthy Safely" />
  </figure>

  <nav class="sidebar-nav" aria-label="Navegação do painel profissional">
    <a href="/profissional/painel-financeiro" class="sidebar-link">
      <i class="bi bi-bar-chart-fill" aria-hidden="true"></i>
      <span>Painel Financeiro</span>
    </a>
    <a href="/profissional/perfil-profissional" class="sidebar-link">
      <i class="bi bi-person-badge-fill" aria-hidden="true"></i>
      <span>Meu Perfil</span>
    </a>
    <a href="/profissional/pacientes" class="sidebar-link">
      <i class="bi bi-people-fill" aria-hidden="true"></i>
      <span>Pacientes</span>
    </a>
    <a href="/profissional/agenda" class="sidebar-link">
      <i class="bi bi-calendar-check-fill" aria-hidden="true"></i>
      <span>Agenda</span>
    </a>

    <section class="sidebar-divider" aria-hidden="true"></section>

    <a href="/ajuda" class="sidebar-link">
      <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
      <span>Ajuda</span>
    </a>
  </nav>

  <nav class="sidebar-sair" aria-label="Sair da conta">
    <a href="/logout" class="sidebar-link">
      <i class="bi bi-box-arrow-left" aria-hidden="true"></i>
      <span>Sair</span>
    </a>
  </nav>
</aside>
