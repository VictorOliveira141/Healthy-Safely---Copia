<%
  /* Detecta a rota atual para marcar link ativo */
  const rotaAtual = typeof currentPath !== 'undefined' ? currentPath : (locals.currentPath || '');
  function isAtivo(path) {
    return rotaAtual.startsWith(path) ? 'ativo' : '';
  }
  const nomeDisplay = (typeof colaborador !== 'undefined' && colaborador && colaborador.nome)
    ? colaborador.nome
    : (typeof usuario !== 'undefined' && usuario && usuario.nome ? usuario.nome : 'Profissional');
  const iniciais = nomeDisplay.split(' ').slice(0,2).map(p=>p[0]).join('').toUpperCase();
%>


