<button id="toggleTema" aria-label="Alternar tema" aria-pressed="false">
  🌙
</button>

<script>
  const btn = document.getElementById("toggleTema");

  function atualizarIcone() {
    if (document.body.classList.contains("dark")) {
      btn.textContent = "🌞"; // modo escuro → mostra sol
    } else {
      btn.textContent = "🌚"; // modo claro → mostra lua
    }
  }

  btn.addEventListener("click", () => {
    document.body.classList.toggle("dark");

    const tema = document.body.classList.contains("dark") ? "dark" : "light";
    localStorage.setItem("tema", tema);

    atualizarIcone(); // atualiza ícone
  });

  // carregar tema salvo
  if (localStorage.getItem("tema") === "dark") {
    document.body.classList.add("dark");
  }

  atualizarIcone(); // define ícone ao carregar
</script>

<style>
  #toggleTema {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);

    background: var(--accent-color);
    color: #fff;

    border: none;
    padding: 12px 10px;
    border-radius: 10px 0 0 10px;

    cursor: pointer;
    z-index: 999;

    font-size: 18px;

    box-shadow: -2px 4px 12px rgba(0, 0, 0, 0.2);
    transition: 0.3s;
  }
</style>
