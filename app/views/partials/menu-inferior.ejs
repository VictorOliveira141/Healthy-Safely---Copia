    z-index: 999;
    display: none; /* começa escondido */
    justify-content: center;
    height: 55px;
    padding: 0;
  }

  .menu-container {
    display: flex;
    max-width: 500px;
    width: 100%;
    gap: 0;
  }
  
  .menu-container .foto-perfil {
