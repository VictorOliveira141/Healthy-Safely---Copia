<link rel="stylesheet" href="/css/header.css" />
<%- include('../partials/menu-inferior.ejs') %>

<header>
  <p class="visually-hidden">
    Navegação principal do site Healthy Safely com acesso a tarefas, perfil, notificações e suporte ao usuário.
  </p>

  <nav
    class="header-nav2 cliente"
    id="mobileNav"
    aria-label="Menu principal do site Healthy Safely"
  >
    <article class="nav-spacer">
      <a href="/tasks">Tarefas</a>
      <a href="/perfil">Perfil</a>
    </article>

    <article class="nav-spacer">
      <button
        class="notification-toggle"
        id="notificationMenuToggleDesktop"
        aria-controls="notificationMenu"
        aria-expanded="false"
      >
        Notificações
      </button>

      <a href="/ajuda?secao=contato">Contato</a>

      <a href="/ajuda">
        <i class="bi bi-info-circle" aria-hidden="true"></i> Ajuda
      </a>
    </article>
  </nav>

  <!-- PARTE VISUAL DO HEADER -->
  <section class="header-container">
    <a
      href="/"
      class="header-logo"
      aria-label="Página inicial da Healthy Safely"
    >
      <img
        src="/imagem/1x/logozeko.png"
        alt="Healthy Safely - Plataforma de hábitos saudáveis"
      />
    </a>

    <nav class="header-actions" aria-label="Ações do usuário">

     <% if (usuario) { %>
  <section class="user-menu cliente" aria-label="Menu de notificações">

    <button
      class="notification-toggle notificacao"
      id="notificationMenuToggleAction"
      aria-controls="notificationMenu"
      aria-expanded="false"
      aria-label="Abrir notificações"
    >
      <i class="bi bi-bell" aria-hidden="true"></i>
    </button>

    <section
      id="notificationMenu"
      class="notification-dropdown hidden"
      role="menu"
    >
      <h3>Notificações</h3>
      <ul id="notificationList">
        <li>Nenhuma notificação nova.</li>
      </ul>
    </section>

  </section>
<% } %>

      <!-- LOGIN / PERFIL -->
      <section class="user-menu cliente">
        <% if (usuario) { %>
          <a href="/perfil" aria-label="Ir para perfil">
            <i class="bi bi-person-circle logado" aria-hidden="true"></i>
          </a>

          <span class="header-welcome">
            Olá, <strong><%= usuario.nome.split(' ')[0] %></strong> 👋
          </span>
        <% } else { %>
          <section class="logar-cadastrar">
            <a href="/perfil" aria-label="Ir para perfil">
              <i class="bi bi-person-circle" aria-hidden="true"></i>
            </a>

            <a href="/login" class="abrir">Entrar</a>
            <span> | </span>
            <a href="/cadastro" class="abrir-cadastro">Cadastrar</a>
          </section>
        <% } %>
      </section>

    </nav>
  </section>
</header>

<!-- MODAL -->
<section
  id="headerModalCadastro"
  class="modal hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modalCadastroTitle"
>
  <section class="modal-content">
    <button id="headerCloseCadastroModal" class="close-btn" aria-label="Fechar">
      &times;
    </button>

    <!-- agora tem ID correto -->
    <p id="modalCadastroTitle" class="titulo-cadastro">
      Cadastrar como:
    </p>

    <section class="opcoes-cadastro">
      <a href="/cadastroCliente" class="btn-cadastro">Usuário</a>
      <a href="/cadastroProfissional" class="btn-cadastro">Profissional</a>
    </section>
  </section>
</section>

<script src="/js/modal-header.js"></script>
