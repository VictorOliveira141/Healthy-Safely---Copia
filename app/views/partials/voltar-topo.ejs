<!-- Partials de um botão para voltar ao topo da página em páginas segundarias. -->

<section class="voltar-topo">
  <button type="button" id="btn-topo">
    <h3>Voltar ao topo</h3>
  </button>
</section>

<style>
  .voltar-topo {
    margin: 20px auto;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 16px;
    border-radius: 10px;
    max-width: 1200px;
    width: 90%;
  }
  .voltar-topo h3 {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 18px 0;
    font-size: 30px;
    font-weight: 600;
    color: var(--fundoclaro);
    white-space: nowrap;
  }
  .voltar-topo h3::before,
  .voltar-topo h3::after {
    content: "";
    height: 1px;
    background: linear-gradient(to right, var(--fundoclaro), var(--fundoclaro));
  }
  .voltar-topo h3::before {
    width: 50%;
  }
  .voltar-topo h3::after {
    width: 50%;
  }
  #btn-topo {
  background: none;
  border: none;
  width: 100%;
  cursor: pointer;
  padding: 0;
}
</style>

<script>
  const btnTopo = document.getElementById("btn-topo");

  if (btnTopo) {
    btnTopo.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    });
  }
</script>
